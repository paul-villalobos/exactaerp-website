<script>
  let activeCurrency = "PEN";
  let currentSoles = 12450;
  let currentDollars = 3365;

  function setupCurrencySwitch() {
    const switchSoles = document.getElementById("currency-switch-soles");
    const switchDolares = document.getElementById("currency-switch-dolares");
    const currencyValues = document.querySelectorAll(".currency-value");

    if (!switchSoles || !switchDolares) return;

    function setCurrency(currency: string) {
      activeCurrency = currency;
      if (currency === "PEN") {
        switchSoles.classList.add("bg-brand-secondary", "text-slate-950");
        switchSoles.classList.remove("text-slate-400", "hover:text-slate-200");
        switchDolares.classList.remove("bg-brand-secondary", "text-slate-950");
        switchDolares.classList.add("text-slate-400", "hover:text-slate-200");
      } else {
        switchDolares.classList.add("bg-brand-secondary", "text-slate-950");
        switchDolares.classList.remove(
          "text-slate-400",
          "hover:text-slate-200",
        );
        switchSoles.classList.remove("bg-brand-secondary", "text-slate-950");
        switchSoles.classList.add("text-slate-400", "hover:text-slate-200");
      }

      currencyValues.forEach((el) => {
        const val = el.getAttribute(
          currency === "PEN" ? "data-pen" : "data-usd",
        );
        if (val) el.textContent = val;
      });

      // Update speedometer live leak amount if present
      const liveLeakAmount = document.getElementById("live-leak-amount");
      if (liveLeakAmount) {
        const rawLeak = parseInt(
          liveLeakAmount.getAttribute("data-value") || "0",
          10,
        );
        if (currency === "PEN") {
          liveLeakAmount.textContent = `S/. ${rawLeak.toLocaleString("es-PE")}`;
        } else {
          const usdLeak = Math.round(rawLeak / 3.7);
          liveLeakAmount.textContent = `$${usdLeak.toLocaleString("en-US")}`;
        }
      }

      // Update assessment widget formatting dynamically when currency changes
      updateAssessment();
    }

    switchSoles.addEventListener("click", () => setCurrency("PEN"));
    switchDolares.addEventListener("click", () => setCurrency("USD"));
  }

  // SELF-ASSESSMENT WIDGET LOGIC
  function updateAssessment() {
    const sliderSucursales = document.getElementById(
      "slider-sucursales",
    ) as HTMLInputElement;
    const sliderSkus = document.getElementById(
      "slider-skus",
    ) as HTMLInputElement;
    const sliderFacturacion = document.getElementById(
      "slider-facturacion",
    ) as HTMLInputElement;

    const valSucursales = document.getElementById("val-sucursales");
    const valSkus = document.getElementById("val-skus");
    const valFacturacion = document.getElementById("val-facturacion");
    const badge = document.getElementById("assessment-badge");
    const feedback = document.getElementById("assessment-feedback");

    if (!sliderSucursales || !sliderSkus || !sliderFacturacion) return;

    const sucs = parseInt(sliderSucursales.value);
    const skus = parseInt(sliderSkus.value);
    const fact = parseInt(sliderFacturacion.value);

    // Update labels
    if (valSucursales) {
      valSucursales.textContent =
        sucs === 1 ? "1 sucursal" : `${sucs} sucursales`;
    }

    if (valSkus) {
      valSkus.textContent =
        skus >= 10000 ? "10,000+ SKUs" : `${skus.toLocaleString("es-PE")} SKUs`;
    }

    if (valFacturacion) {
      valFacturacion.textContent = formatCurrencyValue(fact);
      valFacturacion.setAttribute("data-value", fact.toString());
    }

    // Qualification rule: sucs >= 2 AND skus >= 3000 AND fact >= 5000000
    const qualified = sucs >= 2 && skus >= 3000 && fact >= 5000000;

    if (qualified) {
      if (badge) {
        badge.className =
          "px-2 py-0.5 rounded text-[8px] font-bold font-mono transition-colors uppercase bg-emerald-950 border border-emerald-500/30 text-emerald-400";
        badge.textContent = "COMPATIBLE";
      }
      if (feedback) {
        feedback.className =
          "bg-emerald-950/20 border border-emerald-500/30 rounded-lg p-4 text-[11px] sm:text-xs text-emerald-300 leading-relaxed font-sans transition-all text-left";
        feedback.textContent =
          "Operación Calificada: Tu negocio está perdiendo margen por falta de control. ERP Exacta tiene tu solución pre-configurada.";
      }
    } else {
      if (badge) {
        badge.className =
          "px-2 py-0.5 rounded text-[8px] font-bold font-mono transition-colors uppercase bg-red-950/60 border border-red-500/30 text-red-400";
        badge.textContent = "NO COMPATIBLE";
      }
      if (feedback) {
        feedback.className =
          "bg-red-950/10 border border-red-500/20 rounded-lg p-4 text-[11px] sm:text-xs text-red-300 leading-relaxed font-sans transition-all text-left";
        feedback.textContent =
          "Tu escala de negocio se adaptaría mejor a un facturador tradicional de oficina.";
      }
    }
  }

  function formatCurrencyValue(value: number) {
    if (activeCurrency === "PEN") {
      if (value >= 15000000) return "S/. 15 Millones+";
      if (value >= 1000000)
        return `S/. ${(value / 1000000).toFixed(1).replace(".0", "")} Millones`;
      return `S/. ${value.toLocaleString("es-PE")}`;
    } else {
      const usdVal = Math.round(value / 3.7);
      if (usdVal >= 4000000) return "$4 Millones+";
      if (usdVal >= 1000000)
        return `$${(usdVal / 1000000).toFixed(1).replace(".0", "")} Millones`;
      if (usdVal >= 1000) return `$${Math.round(usdVal / 1000)}K`;
      return `$${usdVal.toLocaleString("en-US")}`;
    }
  }

  function setupAssessmentSlider() {
    const sliderSucursales = document.getElementById("slider-sucursales");
    const sliderSkus = document.getElementById("slider-skus");
    const sliderFacturacion = document.getElementById("slider-facturacion");

    if (!sliderSucursales || !sliderSkus || !sliderFacturacion) return;

    [sliderSucursales, sliderSkus, sliderFacturacion].forEach((slider) => {
      slider.addEventListener("input", updateAssessment);
    });

    // Run initial rendering
    updateAssessment();
  }

  // DYNAMIC DUAL CURRENCY METRICS SIMULATOR (Hero panel)
  function animateKPIs() {
    const kpiEl = document.getElementById("kpi-utilidad-bruta");
    if (!kpiEl) return;

    setInterval(() => {
      // Simulate micro transactions updating live
      const solesDiff = Math.floor(Math.random() * 40) + 10;
      const dollarsDiff = Math.floor(Math.random() * 12) + 3;

      currentSoles += solesDiff;
      currentDollars += dollarsDiff;

      kpiEl.setAttribute(
        "data-pen",
        `S/. ${currentSoles.toLocaleString("es-PE")}`,
      );
      kpiEl.setAttribute(
        "data-usd",
        `$${currentDollars.toLocaleString("en-US")}`,
      );

      if (activeCurrency === "PEN") {
        kpiEl.textContent = `S/. ${currentSoles.toLocaleString("es-PE")}`;
      } else {
        kpiEl.textContent = `$${currentDollars.toLocaleString("en-US")}`;
      }
    }, 3000);
  }

  // AI DIAGNOSTIC CHATBOT WIDGET CONTROLLER
  function setupChatbot() {
    const step1Actions = document.getElementById("step-1-actions");
    const step2Actions = document.getElementById("step-2-actions");
    const step3Actions = document.getElementById("step-3-actions");
    const step4Actions = document.getElementById("step-4-actions");
    const botMsg2 = document.getElementById("bot-msg-2");
    const botMsg3 = document.getElementById("bot-msg-3");
    const botMsg4 = document.getElementById("bot-msg-4");
    const typingIndicator = document.getElementById("typing-indicator");
    const qualificationText = document.getElementById("qualification-text");
    const submitBtn = document.getElementById("btn-submit-diagnostic");
    const whatsappInput = document.getElementById(
      "diag-whatsapp",
    ) as HTMLInputElement;
    const chatContainer = document.getElementById("chat-messages-container");

    const gaugeFill = document.getElementById("gauge-fill");
    const gaugeNeedle = document.getElementById("gauge-needle");
    const liveLeakAmount = document.getElementById("live-leak-amount");
    const riskBadge = document.getElementById("risk-level-badge");

    if (
      !step1Actions ||
      !step2Actions ||
      !step3Actions ||
      !step4Actions ||
      !botMsg2 ||
      !botMsg3 ||
      !botMsg4 ||
      !typingIndicator ||
      !submitBtn ||
      !whatsappInput
    )
      return;

    let points = 0;
    let baseLeakSoles = 0;
    let selectedQ1Text = "";
    let selectedQ2Text = "";
    let selectedQ3Text = "";
    let isDescarte = false;

    // Helper: update gauge visual state
    function updateGaugeVisual(targetLeak: number) {
      if (!gaugeFill || !gaugeNeedle || !liveLeakAmount || !riskBadge) return;

      // Max leak is 18500
      const percentage = Math.min(100, Math.max(0, (targetLeak / 18500) * 100));

      // Arc stroke dashoffset (125.6 is full length of semi-circle arc)
      const offset = 125.6 - (percentage / 100) * 125.6;
      gaugeFill.setAttribute("stroke-dashoffset", offset.toString());

      // Needle rotation from -90deg to 90deg
      const angle = -90 + percentage * 1.8;
      gaugeNeedle.style.transform = `rotate(${angle}deg)`;

      // Risk level mapping
      if (percentage <= 15) {
        riskBadge.textContent = "BAJO";
        riskBadge.className =
          "px-2 py-0.5 rounded text-[10px] font-bold bg-slate-950 border border-slate-800 text-emerald-400";
      } else if (percentage <= 50) {
        riskBadge.textContent = "MEDIO";
        riskBadge.className =
          "px-2 py-0.5 rounded text-[10px] font-bold bg-slate-950 border border-slate-800 text-yellow-500";
      } else {
        riskBadge.textContent = "CRÍTICO / ALTO";
        riskBadge.className =
          "px-2 py-0.5 rounded text-[10px] font-bold bg-slate-950 border border-slate-800 text-red-500 animate-pulse";
      }

      // Money amount: bimonetary translation
      liveLeakAmount.setAttribute("data-value", targetLeak.toString());
      if (activeCurrency === "PEN") {
        liveLeakAmount.textContent = `S/. ${targetLeak.toLocaleString("es-PE")}`;
      } else {
        const usdLeak = Math.round(targetLeak / 3.7);
        liveLeakAmount.textContent = `$${usdLeak.toLocaleString("en-US")}`;
      }
    }

    // Helper: append user message bubble to chat
    function appendUserMessage(text: string) {
      if (!chatContainer) return;
      const bubble = document.createElement("div");
      bubble.className = "flex items-start gap-3 justify-end text-right";
      bubble.innerHTML = `
        <div class="bg-brand-primary text-white border border-brand-primary/20 rounded-lg p-3 max-w-[80%] text-xs sm:text-sm">
          <p>${text}</p>
        </div>
      `;
      chatContainer.insertBefore(bubble, typingIndicator);
      chatContainer.scrollTop = chatContainer.scrollHeight;
    }

    // Step 1 Click (Mostradores)
    const step1Buttons = step1Actions.querySelectorAll(".chat-btn-option");
    step1Buttons.forEach((button) => {
      button.addEventListener("click", (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const pts = parseInt(btn.dataset.points || "0", 10);
        const lk = parseInt(btn.dataset.leak || "0", 10);
        selectedQ1Text = btn.dataset.text || btn.textContent?.trim() || "";

        points += pts;
        baseLeakSoles += lk;
        updateGaugeVisual(baseLeakSoles);

        step1Actions.classList.add("hidden");
        appendUserMessage(selectedQ1Text);

        typingIndicator.classList.remove("hidden");
        if (chatContainer) chatContainer.scrollTop = chatContainer.scrollHeight;

        setTimeout(() => {
          typingIndicator.classList.add("hidden");
          botMsg2.classList.remove("hidden");
          step2Actions.classList.remove("hidden");
          if (chatContainer)
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }, 1200);
      });
    });

    // Step 2 Click (Dolor de cabeza)
    const step2Buttons = step2Actions.querySelectorAll(".chat-btn-option");
    step2Buttons.forEach((button) => {
      button.addEventListener("click", (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const pts = parseInt(btn.dataset.points || "0", 10);
        const lk = parseInt(btn.dataset.leak || "0", 10);
        selectedQ2Text = btn.dataset.text || btn.textContent?.trim() || "";

        points += pts;
        baseLeakSoles += lk;
        updateGaugeVisual(baseLeakSoles);

        step2Actions.classList.add("hidden");
        appendUserMessage(selectedQ2Text);

        typingIndicator.classList.remove("hidden");
        if (chatContainer) chatContainer.scrollTop = chatContainer.scrollHeight;

        setTimeout(() => {
          typingIndicator.classList.add("hidden");
          botMsg3.classList.remove("hidden");
          step3Actions.classList.remove("hidden");
          if (chatContainer)
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }, 1200);
      });
    });

    // Step 3 Click (Facturación)
    const step3Buttons = step3Actions.querySelectorAll(".chat-btn-option");
    step3Buttons.forEach((button) => {
      button.addEventListener("click", (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const pts = parseInt(btn.dataset.points || "0", 10);
        const lk = parseInt(btn.dataset.leak || "0", 10);
        isDescarte = btn.dataset.descarte === "true";
        selectedQ3Text = btn.dataset.text || btn.textContent?.trim() || "";

        points += pts;
        baseLeakSoles += lk;
        updateGaugeVisual(baseLeakSoles);

        step3Actions.classList.add("hidden");
        appendUserMessage(selectedQ3Text);

        typingIndicator.classList.remove("hidden");
        if (chatContainer) chatContainer.scrollTop = chatContainer.scrollHeight;

        setTimeout(() => {
          typingIndicator.classList.add("hidden");

          // Formulate final message based on qualification points
          let formattedLeakStr =
            activeCurrency === "PEN"
              ? `S/. ${baseLeakSoles.toLocaleString("es-PE")}`
              : `$${Math.round(baseLeakSoles / 3.7).toLocaleString("en-US")}`;

          if (isDescarte) {
            qualificationText.innerHTML = `
              Cálculo completado. Según tus respuestas, tu operación tiene un <span class="text-yellow-400 font-bold">Nivel de Fuga Operativa: BAJO / MODERADO</span> (Puntaje estimado de pérdida: ${formattedLeakStr} mensuales).<br/><br/>
              Tu escala comercial indica que te beneficiarías de un facturador contable básico. Sin embargo, si deseas recibir nuestro <strong>Reporte PDF de Diagnóstico Clínico de Márgenes</strong> para optimizar tus procesos futuros, ingresa tu WhatsApp de contacto.
            `;
          } else {
            qualificationText.innerHTML = `
              Cálculo completado. Según tus respuestas, tu operación tiene un <span class="text-red-400 font-bold">Nivel de Fuga Operativa: ALTO</span> (Puntaje estimado de pérdida: <strong class="text-red-400">${formattedLeakStr} mensuales</strong> por quiebres de stock y compras en plaza descontroladas).<br/><br/>
              Tu negocio <strong class="text-emerald-400">califica estructuralmente</strong> para nuestra Garantía de Implementación y Estabilización Express en 30 días.<br/><br/>
              Para enviarte de inmediato a tu WhatsApp el <strong>Reporte PDF de Diagnóstico Clínico de Márgenes</strong> (detallando cómo solucionamos este cuello de botella exacto), ingresa tu número móvil principal. Cero spam, directo a tu teléfono.
            `;
          }

          botMsg4.classList.remove("hidden");
          step4Actions.classList.remove("hidden");
          if (chatContainer)
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }, 1500);
      });
    });

    // Step 4 Click (WhatsApp lead capture)
    submitBtn.addEventListener("click", () => {
      const whatsapp = whatsappInput.value.trim();
      if (!whatsapp) {
        alert(
          "Por favor, ingresa tu celular de WhatsApp para recibir tu Diagnóstico Clínico.",
        );
        return;
      }

      let formattedLeakStr =
        activeCurrency === "PEN"
          ? `S/. ${baseLeakSoles.toLocaleString("es-PE")}`
          : `$${Math.round(baseLeakSoles / 3.7).toLocaleString("en-US")}`;

      const text = `Hola ERP Exacta, acabo de realizar el diagnóstico de fugas de margen en exactaerp.pe.
- Puntos de venta: ${selectedQ1Text}
- Dolor principal: ${selectedQ2Text}
- Rango de facturación: ${selectedQ3Text}
- Fuga Estimada: ${formattedLeakStr} mensuales (Puntaje: ${points} pts)
- WhatsApp de contacto: ${whatsapp}
Deseo recibir de inmediato mi Reporte PDF de Diagnóstico Clínico de Márgenes y programar la llamada técnica de validación.`;

      const waUrl = `https://wa.me/51999647337?text=${encodeURIComponent(text)}`;
      window.open(waUrl, "_blank");
    });
  }

