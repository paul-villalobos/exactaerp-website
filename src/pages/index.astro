---
import LandingLayout from "../layouts/LandingLayout.astro";
import ContactWidget from "../components/ContactWidget.astro";
import { Image } from "astro:assets";
import logoHorizontal from "../assets/logo-horizontal.png";
---

<LandingLayout
  title="ERP Exacta | Sistema de Control Comercial y Márgenes en Vivo"
  description="ERP comercial peruano para importadores, distribuidoras y servicios. Blinda tus márgenes y gestiona tu kárdex SUNAT en tiempo real sin cierres de mes."
  ogImage="/logo-vertical.png"
>
  <!-- Header: Menú de Navegación "Anti-Fugas" -->
  <header
    class="sticky top-0 z-50 w-full border-b border-slate-800 bg-slate-950/80 backdrop-blur-md"
  >
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between"
    >
      <!-- Lado Izquierdo: Logotipo -->
      <a href="#hero" class="flex items-center">
        <Image
          src={logoHorizontal}
          alt="ERP EXACTA"
          height={44}
          class="h-11 w-auto object-contain"
        />
      </a>

      <!-- Centro: Navegación de Anclaje Interno -->
      <nav class="hidden md:flex items-center gap-x-8">
        <a
          href="#musculo-transaccional"
          class="text-sm font-medium text-slate-400 hover:text-slate-100 transition-colors"
        >
          Respaldo y Solidez
        </a>
        <a
          href="#cierre-irresistible"
          class="text-sm font-medium text-slate-400 hover:text-slate-100 transition-colors"
        >
          Doble Garantía
        </a>
      </nav>

      <!-- Lado Derecho: El Botón de Conversión -->
      <div class="flex flex-col items-end">
        <a
          href="https://wa.me/51999647337?text=Hola%20Exacta%20ERP,%20deseo%20solicitar%20una%20demo%20de%20diagnóstico%20en%20mi%20local%20de%20repuestos."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-4 py-2 text-xs sm:text-sm font-bold text-slate-950 bg-brand-secondary hover:bg-brand-secondary-hover rounded-md shadow-lg shadow-brand-secondary/20 transition-all hover:scale-105 active:scale-95"
        >
          <!-- WhatsApp SVG Icon -->
          <svg class="w-4 h-4 mr-2 fill-current" viewBox="0 0 24 24">
            <path
              d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.262 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.73-1.458L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.42 9.863-9.864.002-2.634-1.02-5.11-2.884-6.978C16.578 1.897 14.1 .874 11.482.874 6.044.874 1.622 5.293 1.62 10.733c-.001 1.739.46 3.43 1.333 4.937L1.922 20.3l4.725-1.146zm11.378-6.196c-.302-.151-1.785-.882-2.057-.981-.273-.099-.471-.148-.669.151-.197.297-.767.966-.94 1.164-.173.199-.347.223-.649.072-.302-.15-1.272-.469-2.423-1.496-.895-.798-1.5-.178-1.785-.328-.287-.15-.03-.233.243-.506.244-.244.347-.396.52-.66.173-.264.086-.495-.043-.649-.129-.152-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.568-.01-.197 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.785-.73 2.037-1.435.252-.706.252-1.312.177-1.435-.077-.122-.273-.196-.576-.347z"
            ></path>
          </svg>
          Solicitar Demo
        </a>
      </div>
    </div>
  </header>
  <!-- SECCIÓN 1: HERO SECTION -->
  <section
    id="hero"
    class="relative overflow-hidden pt-12 pb-16 md:py-24 bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 border-b border-slate-900"
  >
    <!-- Background glow accents -->
    <div
      class="absolute top-0 left-1/3 w-[500px] h-[500px] bg-brand-primary/10 rounded-full blur-[100px] -z-10"
    >
    </div>
    <div
      class="absolute bottom-10 right-10 w-[400px] h-[400px] bg-brand-secondary/5 rounded-full blur-[80px] -z-10"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Currency switcher discretely floating at top-right of Hero content -->
      <div class="flex items-center justify-end gap-2 mb-6">
        <span
          class="text-[10px] uppercase font-bold tracking-wider font-mono text-slate-450"
          >Multi-Moneda:</span
        >
        <div
          class="bg-slate-900 border border-slate-800 p-0.5 rounded-lg inline-flex relative"
        >
          <button
            id="currency-switch-soles"
            class="px-3 py-1 rounded-md text-[10px] sm:text-xs font-bold font-mono transition-all bg-brand-secondary text-slate-950 cursor-pointer"
            data-currency="PEN"
          >
            Soles (S/.)
          </button>
          <button
            id="currency-switch-dolares"
            class="px-3 py-1 rounded-md text-[10px] sm:text-xs font-bold font-mono transition-all text-slate-450 hover:text-slate-200 cursor-pointer"
            data-currency="USD"
          >
            Dólares ($)
          </button>
        </div>
      </div>

      <div
        class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center"
      >
        <!-- Left Column: Copy -->
        <div class="lg:col-span-7 space-y-6 text-left">
          <!-- Market Context Cintillo -->
          <div
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-secondary/30 bg-brand-secondary/10"
          >
            <span class="w-2 h-2 rounded-full bg-brand-secondary animate-pulse"
            ></span>
            <span
              class="text-xs font-bold text-orange-350 tracking-wide uppercase font-mono"
            >
              SISTEMA DE CONTROL OPERATIVO Y MÁRGENES DE GANANCIA EN VIVO
            </span>
          </div>

          <!-- Main Title H1 -->
          <h1
            class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-white leading-tight"
          >
            El ERP comercial que toma el control donde los sistemas
            tradicionales se rompen.
          </h1>

          <!-- Support Subtitle H2 -->
          <h2
            class="text-base sm:text-lg text-slate-300 leading-relaxed max-w-2xl"
            data-astro-cid-lcdefpme
          >
            Sincroniza tus almacenes, protege tus márgenes por pedido en vivo y
            automatiza tu Inventario Permanente Valorizado bajo los estándares
            de la SUNAT.
            <span
              class="block mt-2 text-brand-secondary font-semibold font-mono text-xs sm:text-sm"
              >⚡ Control en tiempo real • Sin detener tu mostrador • Sin
              cierres de mes.</span
            >
          </h2>

          <!-- Call to Action -->
          <div class="space-y-3 pt-2">
            <div
              class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4"
            >
            </div>
          </div>
        </div>

        <!-- Right Column: Simulated Management Dashboard (HTML/CSS UI) -->
        <div class="lg:col-span-5 flex justify-center">
          <div
            class="w-full max-w-md bg-slate-900 border border-slate-800 rounded-xl overflow-hidden shadow-2xl relative"
          >
            <!-- Simulated application top bar -->
            <div
              class="bg-slate-950 px-4 py-3 border-b border-slate-800 flex items-center justify-between"
            >
              <div class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-red-500/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-green-500/80"></span>
              </div>
              <span
                class="text-[10px] font-mono text-slate-450 font-bold uppercase tracking-wider"
              >
                ERP Exacta — PANEL GERENCIAL
              </span>
              <span
                class="text-[9px] bg-emerald-950 border border-emerald-800 text-emerald-400 px-2 py-0.5 rounded font-mono font-bold animate-pulse"
              >
                EN VIVO
              </span>
            </div>

            <!-- Dashboard Content -->
            <div
              class="p-4 sm:p-5 space-y-4 bg-slate-950/70 text-slate-100 font-sans"
            >
              <!-- Grid KPIs -->
              <div class="grid grid-cols-2 gap-3">
                <!-- Utilidad Bruta Proyectada del Día -->
                <div
                  class="bg-slate-900 border border-slate-800 p-3.5 rounded-lg relative overflow-hidden group hover:border-slate-700/80 transition-all col-span-2"
                >
                  <span
                    class="text-[9px] text-slate-400 font-bold uppercase block tracking-wider"
                    >Utilidad Bruta Proyectada del Día</span
                  >
                  <div
                    class="text-2xl sm:text-3xl font-black text-white font-mono mt-1 currency-value"
                    id="kpi-utilidad-bruta"
                    data-pen="S/. 12,450"
                    data-usd="$3,365"
                  >
                    S/. 12,450
                  </div>
                  <span
                    class="text-[10px] font-mono font-semibold text-emerald-400 flex items-center gap-1 mt-1"
                  >
                    ▲ +14.2% <span class="text-[8px] text-slate-500 font-normal"
                      >vs ayer</span
                    >
                  </span>
                  <div
                    class="absolute bottom-0 right-0 left-0 h-0.5 bg-gradient-to-r from-emerald-500 to-teal-400"
                  >
                  </div>
                </div>

                <!-- Estado de Pedidos en Mostrador -->
                <div
                  class="bg-slate-900 border border-slate-800 p-3.5 rounded-lg relative overflow-hidden group hover:border-slate-700/80 transition-all col-span-2"
                >
                  <span
                    class="text-[9px] text-slate-400 font-bold uppercase block tracking-wider"
                    >Estado de Pedidos en Mostrador</span
                  >
                  <div
                    class="text-xl sm:text-2xl font-black text-white font-mono mt-1"
                    id="kpi-transito-pedidos"
                  >
                    48 Pedidos
                  </div>
                  <span
                    class="text-[10px] font-mono font-semibold text-sky-400 flex items-center gap-1 mt-1"
                  >
                    ● Almacén de Tránsito en vivo <span
                      class="text-[8px] text-slate-500 font-normal"
                      >sin trabas</span
                    >
                  </span>
                  <div
                    class="absolute bottom-0 right-0 left-0 h-0.5 bg-gradient-to-r from-sky-500 to-indigo-400"
                  >
                  </div>
                </div>
              </div>

              <!-- Alertas de Margen Protegido (Audit/Leak control) -->
              <div class="space-y-1.5">
                <span
                  class="text-[9px] text-slate-450 font-bold uppercase tracking-wider block font-mono"
                  >Control de Fugas de Margen</span
                >
                <div
                  class="bg-red-950/30 border border-red-500/30 rounded p-3 text-red-300 text-[10px] sm:text-[11px] font-mono flex items-start gap-2 shadow-lg"
                >
                  <span class="text-red-500 animate-pulse text-xs">⛔</span>
                  <div>
                    <strong class="font-bold text-red-400 block text-[10px]"
                      >ALERTA DE DESVIACIÓN DE MARGEN:</strong
                    >
                    Vendedor <span class="text-white font-semibold"
                      >"Tienda 1"</span
                    > intentó vender por debajo del margen mínimo: <span
                      class="text-red-400 font-bold uppercase">BLOQUEADO</span
                    >
                  </div>
                </div>
              </div>
            </div>

            <!-- Dashboard Footer -->
            <div
              class="p-3 bg-slate-900 border-t border-slate-800 text-[10px] text-slate-400 flex items-center justify-between"
            >
              <span>Auditoría de márgenes activa</span>
              <span class="font-mono text-[9px] text-slate-500"
                >Módulos: Inventario / Importación / SUNAT</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 4: CONSOLIDACIÓN DE AUTORIDAD Y PRUEBA DE FUEGO TRANSACCIONAL -->
  <section
    id="musculo-transaccional"
    class="py-24 bg-slate-950 border-b border-slate-900 relative"
  >
    <!-- Visual background grid/accents -->
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,#0f172a_1px,transparent_1px),linear-gradient(to_bottom,#0f172a_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-20 pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
        <span
          class="text-xs font-bold text-brand-secondary uppercase tracking-wider font-mono px-2.5 py-0.5 rounded border border-brand-secondary/20 bg-orange-950/20"
        >
          RESPALDO TECNOLÓGICO Y SOLIDEZ EMPRESARIAL
        </span>
        <h2
          class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-white tracking-tight leading-tight pt-2"
        >
          La tranquilidad de operar con la infraestructura que sostiene a los
          líderes de la industria en el Perú.
        </h2>
        <p
          class="text-slate-400 text-xs sm:text-sm md:text-base leading-relaxed font-sans max-w-2xl mx-auto"
        >
          ERP Exacta no es un software improvisado. Cuenta con el respaldo de
          ingeniería de <strong>Palestra Sistemas</strong>, organización con
          certificación global DUNS y más de 30 años desarrollando e
          implementando soluciones críticas para medianas y grandes empresas en
          América Latina. Nuestra tecnología soporta y audita operaciones de
          alta transaccionalidad sin caídas del sistema.
        </p>
      </div>

      <!-- 3 Columns of Impact (Prueba de Fuego) -->
      <div
        class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center max-w-5xl mx-auto mb-20"
      >
        <!-- Stat 1: +30 Años -->
        <div
          class="bg-slate-900/40 border border-slate-850/80 p-8 rounded-2xl relative overflow-hidden group hover:border-brand-secondary/30 transition-colors"
        >
          <div
            class="text-3xl sm:text-4xl font-black text-brand-secondary font-mono tracking-tight"
          >
            +30 Años
          </div>
          <p
            class="text-xs sm:text-sm text-slate-200 font-bold uppercase tracking-wider mt-3"
          >
            Ingeniería de Gestión
          </p>
          <p class="text-[11px] sm:text-xs text-slate-400 mt-2 leading-relaxed">
            De experiencia en diseño, desarrollo y estabilización de sistemas de
            gestión comercial en el Perú y Latinoamérica.
          </p>
        </div>

        <!-- Stat 2: +3 Millones / Counter -->
        <div
          class="bg-slate-900/40 border border-slate-850/80 p-8 rounded-2xl relative overflow-hidden group hover:border-brand-primary/30 transition-colors"
        >
          <div class="flex items-center justify-center gap-1.5">
            <span
              class="text-3xl sm:text-4xl font-black text-white font-mono tracking-tight"
            >
              +<span id="live-transaction-counter"
                >3.4<span
                  class="text-base sm:text-lg font-medium text-slate-400 font-sans ml-1"
                  >Millones</span
                ></span
              >
            </span>
            <span class="relative flex h-2 w-2">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
              ></span>
            </span>
          </div>
          <p
            class="text-xs sm:text-sm text-slate-200 font-bold uppercase tracking-wider mt-3"
          >
            Registros Procesados
          </p>
          <p class="text-[11px] sm:text-xs text-slate-400 mt-2 leading-relaxed">
            De transacciones y registros mensuales procesados y auditados de
            forma segura por nuestros motores sin pérdida de información.
          </p>
        </div>

        <!-- Stat 3: Certificado DUNS -->
        <div
          class="bg-slate-900/40 border border-slate-850/80 p-8 rounded-2xl relative overflow-hidden group hover:border-brand-secondary/30 transition-colors"
        >
          <div
            class="text-3xl sm:text-4xl font-black text-emerald-400 font-mono tracking-tight"
          >
            DUNS 934-469-336
          </div>
          <p
            class="text-xs sm:text-sm text-slate-200 font-bold uppercase tracking-wider mt-3"
          >
            Certificación Global
          </p>
          <p class="text-[11px] sm:text-xs text-slate-400 mt-2 leading-relaxed">
            Registro internacional que nos valida como proveedor tecnológico
            seguro y financieramente confiable a nivel global.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 6: EL CIERRE IRRESISTIBLE -->
  <section
    id="cierre-irresistible"
    class="py-20 border-t border-slate-900 bg-slate-950/60 relative overflow-hidden"
  >
    <!-- Glow effects -->
    <div
      class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-brand-primary/5 rounded-full blur-3xl pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span
          class="px-3 py-1 text-[10px] font-mono font-black tracking-[0.2em] bg-slate-900 border border-slate-800 text-brand-secondary rounded uppercase"
        >
          CERO RIESGO OPERATIVO Y COMPROMISO DE ADOPCIÓN
        </span>
        <h2
          class="text-2xl sm:text-4xl font-extrabold text-white tracking-tight mt-6 leading-tight"
        >
          Estabilizamos tu mostrador y blindamos tu kárdex tributario, sin
          sobrecostos por demoras.
        </h2>
        <p
          class="text-xs sm:text-sm text-slate-400 mt-4 leading-relaxed font-sans text-center"
        >
          Entendemos perfectamente tu desconfianza. En el Perú, muchas
          implementaciones de ERP se vuelven eternas, llenas de sobrecostos
          sorpresa y resistencia de tu personal. ERP Exacta elimina el peligro
          con una doble garantía de ingeniería comercial, respaldada por la
          solidez de Palestra Sistemas.
        </p>
      </div>

      <!-- Main Two-Column Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Left Column: Sello de Garantía -->
        <div
          class="lg:col-span-4 flex flex-col items-center justify-center text-center"
        >
          <div class="relative w-52 h-52 flex items-center justify-center">
            <!-- Glowing back effect -->
            <div
              class="absolute inset-0 bg-brand-secondary/15 rounded-full blur-2xl animate-pulse"
            >
            </div>
            <!-- Gold circular rotating ring -->
            <svg
              class="w-full h-full animate-[spin_25s_linear_infinite]"
              viewBox="0 0 200 200"
            >
              <path
                id="badgePath"
                d="M 100, 100 m -70, 0 a 70,70 0 1,1 140,0 a 70,70 0 1,1 -140,0"
                fill="none"></path>
              <text
                class="fill-slate-400 font-mono text-[9px] uppercase tracking-[0.14em] font-black"
              >
                <textPath href="#badgePath" startOffset="0%">
                  • 30-Day Time-To-Value Guaranteed • Palestra Sistemas
                </textPath>
              </text>
            </svg>
            <!-- Center Lacre/Seal -->
            <div
              class="absolute inset-6 rounded-full bg-slate-950 border border-brand-secondary/40 flex flex-col items-center justify-center p-4 text-center shadow-2xl"
            >
              <span
                class="text-amber-400 text-3xl mb-1 filter drop-shadow-[0_2px_8px_rgba(245,158,11,0.3)]"
                >🛡️</span
              >
              <span
                class="text-[8px] font-bold text-slate-400 uppercase tracking-widest leading-none text-center"
                >Garantía de</span
              >
              <span
                class="text-xs font-black text-white uppercase tracking-wider mt-0.5 text-center"
                >Palestra Sistemas</span
              >
            </div>
          </div>
        </div>

        <!-- Right Column: Apilamiento de Garantías -->
        <div class="lg:col-span-8 space-y-6">
          <!-- Garantía 1 -->
          <div
            class="bg-slate-950/60 border border-slate-900 hover:border-slate-800 rounded-xl p-6 transition-all duration-300 relative group"
          >
            <div
              class="absolute -top-3 left-6 px-3 py-0.5 bg-brand-primary/20 border border-brand-primary/30 rounded text-[9px] font-mono font-bold text-brand-primary uppercase tracking-wider"
            >
              Puesta en marcha garantizada
            </div>
            <div class="flex items-start gap-4">
              <div
                class="w-8 h-8 rounded-lg bg-brand-primary/10 border border-brand-primary/20 flex items-center justify-center text-sm shrink-0"
              >
                🤝
              </div>
              <div class="space-y-2 text-left">
                <h3
                  class="text-sm font-bold text-white group-hover:text-brand-secondary transition-colors"
                >
                  Garantía 1: Adopción e Implementación en 30 Días
                </h3>
                <p class="text-xs text-slate-400 leading-relaxed font-sans">
                  "Garantizamos que tu sistema ERP Exacta estará técnicamente
                  listo y tu personal de ventas estará 100% capacitado para
                  operar a la velocidad de la calle."
                </p>
              </div>
            </div>
          </div>

          <!-- Garantía 2 -->
          <div
            class="bg-slate-950/60 border border-slate-900 hover:border-slate-800 rounded-xl p-6 transition-all duration-300 relative group"
          >
            <div
              class="absolute -top-3 left-6 px-3 py-0.5 bg-emerald-500/10 border border-emerald-500/20 rounded text-[9px] font-mono font-bold text-emerald-400 uppercase tracking-wider"
            >
              La continuidad de tu mostrador es sagrada
            </div>
            <div class="flex items-start gap-4">
              <div
                class="w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-sm shrink-0"
              >
                🛠️
              </div>
              <div class="space-y-2 text-left">
                <h3
                  class="text-sm font-bold text-white group-hover:text-emerald-400 transition-colors"
                >
                  Garantía 2: Consistencia Técnica y Estabilidad 24/7
                </h3>
                <p class="text-xs text-slate-400 leading-relaxed font-sans">
                  "Garantizamos que la arquitectura de ERP Exacta genera y
                  exporta de forma consistente tus Libros Electrónicos e
                  Inventario Permanente Valorizado de acuerdo con los estándares
                  y estructuras técnicas vigentes de la SUNAT."
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA Definitivo -->
      <div class="text-center mt-16 max-w-xl mx-auto space-y-4">
        <button
          id="btn-schedule-feasibility"
