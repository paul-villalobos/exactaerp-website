      },
      "garmic group": {
        title: "Cómo Garmic Group automatizó su tesorería en vivo",
        before:
          "Pagos de facturas duplicados y retraso en cobranza por falta de alertas financieras.",
        after:
          "Alertas automáticas de vencimiento de crédito y conciliación bancaria integrada en línea.",
        metric: "Cuentas por cobrar optimizadas al 98%",
      },
      topitop: {
        title: "Cómo Topitop respalda su cadena logística",
        before:
          "Procesamiento lento de despachos inter-almacenes y rigidez en reportes gerenciales nacionales.",
        after:
          "Integración contable robusta para transacciones logísticas complejas sin interrupción de servicios.",
        metric: "Ingeniería transaccional de alta escala",
      },
    };

    const modal = document.getElementById("lightbox-modal");
    const closeBtn = document.getElementById("close-lightbox");
    const titleEl = document.getElementById("lightbox-title");
    const beforeEl = document.getElementById("lightbox-before");
    const afterEl = document.getElementById("lightbox-after");
    const metricEl = document.getElementById("lightbox-metric");
    const logoBtns = document.querySelectorAll(".logo-btn");

    if (!modal || !closeBtn || !titleEl || !beforeEl || !afterEl || !metricEl)
      return;

    logoBtns.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const key = target.dataset.id || "";
        const data = caseStudies[key];

        if (data) {
          titleEl.textContent = data.title;
          beforeEl.textContent = data.before;
          afterEl.textContent = data.after;
          metricEl.textContent = data.metric;

          // Open Modal
          modal.classList.remove("hidden");
          setTimeout(() => {
            modal.classList.remove("opacity-0");
            modal.classList.add("opacity-100");
          }, 10);
        }
      });
    });

    function closeModal() {
      if (!modal) return;
      modal.classList.remove("opacity-100");
      modal.classList.add("opacity-0");
      setTimeout(() => {
        modal.classList.add("hidden");
      }, 300);
    }

    closeBtn.addEventListener("click", closeModal);
    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });
  }

  // SCROLL-CONTROLLED STICKY BOTTOM BAR
  function setupStickyBar() {
    const stickyBar = document.getElementById("sticky-bar");
    const contactWidget = document.getElementById("contact-widget-container");

    window.addEventListener("scroll", () => {
      if (stickyBar) {
        // Show when user scrolls down past 600px
        if (window.scrollY > 600) {
          stickyBar.classList.remove("translate-y-24");
          stickyBar.classList.add("translate-y-0");

          // Shift floating widgets up to avoid overlap with sticky bar
          if (contactWidget) {
            contactWidget.classList.remove("bottom-6");
            contactWidget.classList.add("bottom-24");
          }
        } else {
          stickyBar.classList.remove("translate-y-0");
          stickyBar.classList.add("translate-y-24");

          // Restore floating elements down
          if (contactWidget) {
            contactWidget.classList.remove("bottom-24");
            contactWidget.classList.add("bottom-6");
          }
        }
      }
    });
  }

  // INTERACTIVE PROGRESS STEPS (Adoption Timeline)
  function setupAdoptionSteps() {
    const steps = document.querySelectorAll(".adoption-step");
    const progressBar = document.getElementById("adoption-progress-bar");

    if (steps.length === 0 || !progressBar) return;

    steps.forEach((step, idx) => {
      step.addEventListener("mouseenter", () => {
        const stepNum = idx + 1;
        const progressPercentage = (stepNum / steps.length) * 100;
        progressBar.style.width = `${progressPercentage}%`;

        // Update step visual states
        steps.forEach((s, sIdx) => {
          const numEl = s.querySelector(".step-num");
          if (!numEl) return;
          if (sIdx <= idx) {
            numEl.classList.add(
              "border-brand-secondary",
              "text-brand-secondary",
            );
            numEl.classList.remove("border-slate-900", "text-slate-600");
          } else {
            numEl.classList.add("border-slate-900", "text-slate-600");
            numEl.classList.remove(
              "border-brand-secondary",
              "text-brand-secondary",
            );
          }
        });
      });
    });
  }

  // CTA FEASIBILITY DRILLDOWN TO SCHEDULER DRAWER
  function setupFeasibilityCTA() {
    const feasibilityBtn = document.getElementById("btn-schedule-feasibility");
    const schedulerTrigger = document.getElementById("scheduler-trigger");
    const optScheduleBtn = document.getElementById("btn-opt-schedule");

    if (!feasibilityBtn) return;

    feasibilityBtn.addEventListener("click", () => {
      if (schedulerTrigger) {
        // Toggle the drawer if it is closed
        const drawer = document.getElementById("scheduler-drawer");
        if (drawer && drawer.classList.contains("opacity-0")) {
          schedulerTrigger.click();
        }
        if (optScheduleBtn) {
          optScheduleBtn.click();
        }
      }
    });
  }

  // Run initializers when DOM is fully loaded
  document.addEventListener("DOMContentLoaded", () => {
    setupCurrencySwitch();
    setupAssessmentSlider();
    animateKPIs();

    setupLightboxModal();
    setupChatbot();
    setupStickyBar();
    setupAdoptionSteps();
    setupFeasibilityCTA();
  });
</script>

<style>
  /* Infinite Horizontal Scrolling Animation */
  .marquee-track {
    animation: scroll-marquee 25s linear infinite;
  }

  @keyframes scroll-marquee {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(-50%, 0, 0);
    }
  }

  /* Chat button hover styling */
  .chat-btn-option:hover {
    box-shadow: 0 4px 12px rgba(242, 116, 39, 0.15);
  }

  @keyframes marquee-arrow {
    0% {
      transform: translate3d(-100%, 0, 0);
    }
    100% {
      transform: translate3d(250%, 0, 0);
    }
  }

  .animate-marquee-arrow {
    animation: marquee-arrow 2.5s linear infinite;
  }
</style>
