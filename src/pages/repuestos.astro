<script>
  // VSL INTERACTIVE YOUTUBE PLAYER
  const playBtn = document.getElementById("vsl-play-btn");
  const thumbnail = document.getElementById("vsl-thumbnail");
  const iframe = document.getElementById("vsl-iframe") as HTMLIFrameElement;
  const closeVideoBtn = document.getElementById("vsl-close-btn");

  playBtn?.addEventListener("click", () => {
    if (thumbnail && iframe && playBtn && closeVideoBtn) {
      // Hide play button and thumbnail
      playBtn.classList.add("hidden");
      thumbnail.classList.add("opacity-0");
      setTimeout(() => {
        thumbnail.classList.add("hidden");
        // Load and show youtube video using nocookie and anti-distraction parameters
        iframe.src =
          "https://www.youtube-nocookie.com/embed/CA_VNI0L_88?autoplay=1&controls=0&rel=0&modestbranding=1";
        iframe.classList.remove("hidden");
        closeVideoBtn.classList.remove("hidden");
      }, 300);
    }
  });

  closeVideoBtn?.addEventListener("click", () => {
    if (thumbnail && iframe && playBtn && closeVideoBtn) {
      // Stop video immediately by resetting src
      iframe.src = "";
      iframe.classList.add("hidden");
      closeVideoBtn.classList.add("hidden");

      // Restore thumbnail and play button
      thumbnail.classList.remove("hidden");
      setTimeout(() => {
        thumbnail.classList.remove("opacity-0");
        playBtn.classList.remove("hidden");
      }, 50);
    }
  });

  // ACCORDION Q&A TOGGLER
  document.querySelectorAll(".faq-trigger").forEach((button) => {
    button.addEventListener("click", (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      const targetId = btn.dataset.target || "";
      const content = document.getElementById(targetId);
      const icon = btn.querySelector(".faq-icon");

      if (content && icon) {
        const isOpen =
          content.style.maxHeight && content.style.maxHeight !== "0px";

        // Close all other accordions first (Single accordion mode)
        document.querySelectorAll(".faq-content").forEach((el) => {
          (el as HTMLElement).style.maxHeight = "0px";
        });
        document.querySelectorAll(".faq-icon").forEach((el) => {
          (el as HTMLElement).textContent = "+";
        });

        if (!isOpen) {
          content.style.maxHeight = `${content.scrollHeight}px`;
          icon.textContent = "−";
        } else {
          content.style.maxHeight = "0px";
          icon.textContent = "+";
        }
      }
    });
  });

  // TESTIMONIALS TOGGLER
  const testimonialButtons = document.querySelectorAll(".testimonial-btn");
  const testimonialPanes = document.querySelectorAll(".testimonial-pane");

  testimonialButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const targetId = btn.getAttribute("data-target");

      // Update button active state classes
      testimonialButtons.forEach((b) => {
        const isCurrent = b === btn;
        b.classList.toggle("border-orange-300", isCurrent);
        b.classList.toggle("bg-slate-800/50", isCurrent);
        b.classList.toggle("scale-105", isCurrent);
        b.classList.toggle("border-slate-800", !isCurrent);
        b.classList.toggle("bg-slate-900", !isCurrent);
        b.classList.toggle("scale-100", !isCurrent);
      });

      // Update panes with hidden/visible transitions
      testimonialPanes.forEach((pane) => {
        const paneId = pane.getAttribute("id");
        if (paneId === `testi-${targetId}`) {
          pane.classList.remove("hidden");
          setTimeout(() => {
            pane.classList.remove("opacity-0");
          }, 20);
        } else {
          pane.classList.add("opacity-0");
          pane.classList.add("hidden");
        }
      });
    });
  });

  // SCROLL-CONTROLLED STICKY BOTTOM BAR
  const stickyBar = document.getElementById("sticky-bar");
  const contactWidget = document.getElementById("contact-widget-container");

  window.addEventListener("scroll", () => {
    if (stickyBar) {
      // Show when user scrolls down past hero (e.g. 600px)
      if (window.scrollY > 600) {
        stickyBar.classList.remove("translate-y-24");
        stickyBar.classList.add("translate-y-0");

        // Shift floating elements up to avoid overlap with sticky bar
        if (contactWidget) {
          contactWidget.classList.remove("bottom-6");
          contactWidget.classList.add("bottom-24");
        }
      } else {
        stickyBar.classList.remove("translate-y-0");
        stickyBar.classList.add("translate-y-24");

        // Restore floating elements down
        if (contactWidget) {
          contactWidget.classList.remove("bottom-24");
          contactWidget.classList.add("bottom-6");
        }
      }
    }
  });
</script>

