---
import LandingLayout from "../layouts/LandingLayout.astro";
import ContactWidget from "../components/ContactWidget.astro";
import { Image } from "astro:assets";
import logoHorizontal from "../assets/logo-horizontal.png";
---

<LandingLayout
  title="ERP Exacta - Sistema de Gestión para Distribuidoras de Repuestos"
  description="Vende sin stock de forma controlada, compra en plaza y vuela en mostrador. Control de margen en tiempo real, costeo de importaciones y contabilidad SUNAT."
  ogImage="/ERP-Exacta_Repuestos_Almacen.png"
>
  <!-- Header: Menú de Navegación "Anti-Fugas" -->
  <header
    class="sticky top-0 z-50 w-full border-b border-slate-800 bg-slate-950/80 backdrop-blur-md"
  >
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between"
    >
      <!-- Lado Izquierdo: Logotipo -->
      <a href="#hero" class="flex items-center">
        <Image
          src={logoHorizontal}
          alt="ERP EXACTA"
          height={44}
          class="h-11 w-auto object-contain"
        />
      </a>

      <!-- Centro: Navegación de Anclaje Interno -->
      <nav class="hidden md:flex items-center gap-x-8">
        <a
          href="#dolores"
          class="text-sm font-medium text-slate-400 hover:text-slate-100 transition-colors"
        >
          ¿Qué resolvemos?
        </a>
        <a
          href="#sistema"
          class="text-sm font-medium text-slate-400 hover:text-slate-100 transition-colors"
        >
          El Sistema
        </a>
        <a
          href="#prueba-fuego"
          class="text-sm font-medium text-slate-400 hover:text-slate-100 transition-colors"
        >
          Clientes Líderes
        </a>
      </nav>

      <!-- Lado Derecho: El Botón de Conversión -->
      <div class="flex flex-col items-end">
        <a
          href="https://wa.me/51999647337?text=Hola%20Exacta%20ERP,%20deseo%20solicitar%20una%20demo%20de%20diagnóstico%20en%20mi%20local%20de%20repuestos."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-4 py-2 text-xs sm:text-sm font-bold text-slate-950 bg-brand-secondary hover:bg-brand-secondary-hover rounded-md shadow-lg shadow-brand-secondary/20 transition-all hover:scale-105 active:scale-95"
        >
          <!-- WhatsApp SVG Icon -->
          <svg class="w-4 h-4 mr-2 fill-current" viewBox="0 0 24 24">
            <path
              d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.262 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.73-1.458L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.42 9.863-9.864.002-2.634-1.02-5.11-2.884-6.978C16.578 1.897 14.1 .874 11.482.874 6.044.874 1.622 5.293 1.62 10.733c-.001 1.739.46 3.43 1.333 4.937L1.922 20.3l4.725-1.146zm11.378-6.196c-.302-.151-1.785-.882-2.057-.981-.273-.099-.471-.148-.669.151-.197.297-.767.966-.94 1.164-.173.199-.347.223-.649.072-.302-.15-1.272-.469-2.423-1.496-.895-.798-1.5-.178-1.785-.328-.287-.15-.03-.233.243-.506.244-.244.347-.396.52-.66.173-.264.086-.495-.043-.649-.129-.152-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.568-.01-.197 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.785-.73 2.037-1.435.252-.706.252-1.312.177-1.435-.077-.122-.273-.196-.576-.347z"
            ></path>
          </svg>
          Solicitar Demo
        </a>
      </div>
    </div>
  </header>
  <!-- HERO SECTION: El Gancho de Categoría Radical -->
  <section
    id="hero"
    class="relative overflow-hidden pt-12 pb-24 md:py-32 bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 border-b border-slate-900"
  >
    <!-- Subtle Background Accents -->
    <div
      class="absolute top-0 left-1/4 w-96 h-96 bg-brand-primary/10 rounded-full blur-3xl -z-10"
    >
    </div>
    <div
      class="absolute bottom-10 right-1/4 w-96 h-96 bg-brand-secondary/5 rounded-full blur-3xl -z-10"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center"
      >
        <!-- Left Side Copy -->
        <div class="lg:col-span-7 space-y-6 text-left">
          <!-- Cintillo -->
          <div
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-secondary/30 bg-brand-secondary/10"
          >
            <span class="w-2 h-2 rounded-full bg-brand-secondary animate-pulse"
            ></span>
            <span
              class="text-xs font-bold text-orange-300 tracking-wide uppercase"
            >
              DISEÑADO EXCLUSIVAMENTE PARA MAYORISTAS Y MINORISTAS AUTOMOTRICES
              EN EL PERÚ
            </span>
          </div>

          <!-- Titular Principal H1 -->
          <h1
            class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-white leading-tight"
          >
            Vende sin stock, compra en plaza, cuadra tus inventarios y vuela en
            mostrador... <span
              class="text-transparent bg-clip-text bg-gradient-to-r from-brand-secondary to-orange-300"
              >sin que tus vendedores reduzcan margen</span
            >.
          </h1>

          <!-- Subtitular H2 -->
          <p
            class="text-base sm:text-lg text-slate-300 leading-relaxed max-w-2xl"
          >
            Creado para REPUESTERAS que combinan la velocidad del mostrador con
            la complejidad de miles de repuestos y sus aplicaciones en
            diferentes marcas y modelos de carros. Protege tu rentabilidad <strong
              class="text-slate-100 font-semibold"
              >controlando la utilidad por pedido en vivo</strong
            > y mantén tu Inventario Permanente Valorizado en línea con las exigencias
            vigentes de la SUNAT, sin procesos de cierre.
          </p>

          <!-- Main Call to Actions -->
          <div
            class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 pt-4"
          >
            <a
              href="https://wa.me/51999647337?text=Hola%20Exacta%20ERP,%20deseo%20iniciar%20el%20diagn%C3%B3stico%20de%20mi%20distribuidora%20de%20repuestos."
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-8 py-4 bg-brand-secondary hover:bg-brand-secondary-hover text-slate-950 font-bold text-base rounded-md shadow-xl shadow-brand-secondary/20 hover:shadow-brand-secondary/30 transition-all hover:scale-105 active:scale-95 text-center"
            >
              Iniciar Diagnóstico
            </a>
            <div class="flex flex-col text-left justify-center px-1">
              <span
                class="text-xs text-slate-100 font-bold flex items-center gap-1"
              >
                <svg
                  class="w-3.5 h-3.5 text-green-400 fill-current"
                  viewBox="0 0 20 20"
                >
                  <path
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  ></path>
                </svg>
                Toma menos de 2 minutos vía chat.
              </span>
            </div>
          </div>
        </div>

        <!-- Right Side: VSL Interactive Mock Player -->
        <div class="lg:col-span-5 flex justify-center">
          <div
            class="w-full max-w-md bg-slate-900 border border-slate-800 rounded-xl overflow-hidden shadow-2xl relative group"
          >
            <!-- Video Mock Canvas -->
            <div
              id="vsl-video-player"
              class="relative aspect-video bg-slate-950 flex flex-col items-center justify-center overflow-hidden w-full"
            >
              <!-- Real YouTube Player (Loads on demand) -->
              <iframe
                id="vsl-iframe"
                class="absolute inset-0 w-full h-full hidden"
                src=""
                title="Exacta ERP Demo Video"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen></iframe>

              <!-- Close Video Button (Hidden by default, shown when video plays) -->
              <button
                id="vsl-close-btn"
                class="hidden absolute top-3 right-3 z-20 bg-slate-950/80 hover:bg-slate-900/95 border border-slate-700 text-white rounded px-2.5 py-1 text-xs font-semibold cursor-pointer transition-all hover:scale-105 active:scale-95 flex items-center gap-1 shadow-lg"
                aria-label="Cerrar video y regresar"
              >
                ✕ Cerrar Video
              </button>

              <!-- Background Thumbnail Image / Mock System Panel -->
              <div
                id="vsl-thumbnail"
                class="absolute inset-0 bg-slate-900 p-4 flex flex-col justify-between transition-opacity duration-300"
              >
                <!-- Top Mock Bar -->
                <div
                  class="flex items-center justify-between border-b border-slate-800 pb-2"
                >
                  <span
                    class="text-[10px] font-mono text-orange-300 flex items-center gap-1.5"
                  >
                    <span
                      class="w-1.5 h-1.5 rounded-full bg-brand-secondary animate-pulse"
                    ></span>
                    EXACTA ERP - VISTA MOSTRADOR
                  </span>
                  <span
                    class="text-[9px] bg-slate-800 text-slate-100 px-1.5 py-0.5 rounded font-mono"
                    >STOCK: 0</span
                  >
                </div>

                <!-- Center Code/Sales Simulator graphic -->
                <div
                  class="flex flex-col items-center justify-center py-4 space-y-2"
                >
                  <div
                    class="w-48 bg-slate-800/80 p-2.5 rounded border border-slate-700/50 flex flex-col space-y-1"
                  >
                    <div class="h-2 w-16 bg-slate-600 rounded"></div>
                    <div
                      class="h-3 w-36 bg-brand-secondary/20 rounded border border-brand-secondary/30"
                    >
                    </div>
                    <div class="h-2 w-24 bg-slate-600 rounded"></div>
                  </div>
                  <span class="text-[11px] text-slate-400 font-medium"
                    >Ver video de demostración</span
                  >
                </div>

                <!-- Aspect Ratio Video Bottom Overlay -->
                <div
                  class="flex items-center justify-between text-[10px] text-slate-400 pt-1.5 border-t border-slate-800/50"
                >
                  <span>Demostración: Exacta ERP</span>
                  <span>Video</span>
                </div>
              </div>

              <!-- Overlaid Big Play Button (when not playing) -->
              <button
                id="vsl-play-btn"
                class="relative z-10 w-16 h-16 rounded-full bg-brand-secondary hover:bg-brand-secondary-hover text-slate-950 flex items-center justify-center shadow-lg transition-transform duration-200 hover:scale-110 active:scale-95 cursor-pointer"
                aria-label="Reproducir video demostración"
              >
                <!-- Play Triangle -->
                <svg class="w-6 h-6 fill-current ml-1" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"></path>
                </svg>
              </button>
            </div>

            <!-- Video Info Footer -->
            <div class="p-4 bg-slate-900 border-t border-slate-800">
              <span class="text-xs font-semibold text-white block"
                >Caso Práctico: Vender sin stock de forma controlada</span
              >
              <p class="text-[11px] text-slate-400 mt-1">
                Mira en 45 segundos cómo un vendedor despacha un repuesto con
                stock cero sin parar la venta.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BLOQUE 2: EL DOLOR PRINCIPAL (Nueva Sección) -->
  <section
    id="dolor-principal"
    class="py-20 bg-slate-50 border-b border-slate-200"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Columna Izquierda (60%): Titulares y 4 puntos de dolor -->
        <div class="lg:col-span-7 space-y-6 text-left">
          <!-- Titular de Alerta (H2) -->
          <h2
            class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-slate-900 leading-tight"
          >
            🔴 El verdadero infierno del mostrador: Tu cliente no espera, se va
            al costado
          </h2>

          <!-- Subtitular de Impacto Financiero (H3) -->
          <h3
            class="text-lg sm:text-xl font-bold text-brand-primary-hover leading-snug"
          >
            ¿Cuántas ventas se te están escapando a la tienda vecina solo porque
            tu vendedor tarda más de 60 segundos en descifrar un código, cotizar
            una compatibilidad, encontrar un precio o comprar en plaza?
          </h3>

          <!-- Párrafo de Agitación de Contexto -->
          <p class="text-sm sm:text-base text-slate-700 leading-relaxed">
            En las tiendas de repuestos automotrices de alta competencia en el
            Perú, el cliente no tiene paciencia. Si tu mostrador se congestiona,
            la venta se enfría y el dinero se va a la competencia. Hoy, tu
            velocidad de atención está secuestrada por 4 problemas críticos de
            tu sistema actual:
          </p>

          <!-- Bloques de Síntomas Operativos (Acordeón UI) -->
          <div class="space-y-3 mt-6">
            <!-- Dolor 1 -->
            <div
              class="border border-slate-200 rounded-lg bg-white shadow-sm overflow-hidden transition-all duration-300 hover:shadow-md pain-accordion-item"
            >
              <button
                type="button"
                class="pain-trigger w-full px-5 py-4 flex items-center justify-between text-left text-sm sm:text-base font-bold text-slate-800 hover:text-slate-900 transition-colors cursor-pointer outline-none"
                data-target="pain-ans-1"
              >
                <span class="flex items-center gap-3">
                  <span class="text-lg flex-shrink-0">📍</span>
                  <span>El Laberinto de Códigos Cruzados</span>
                </span>
                <span
                  class="text-brand-secondary text-lg font-mono leading-none font-bold pain-icon transition-transform duration-300"
                  >+</span
                >
              </button>
              <div
                id="pain-ans-1"
                class="pain-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out"
              >
                <p
                  class="px-5 pb-4 pt-1 text-xs sm:text-sm text-slate-600 leading-relaxed pl-11"
                >
                  Un mismo rodaje, alternador o zapata tiene el código de
                  fábrica, el código alternativo de marca y tu propio código
                  interno. Tu vendedor pierde minutos valiosos buscando en
                  cuadernos o pantallas rígidas en lugar de cerrar la venta al
                  instante.
                </p>
              </div>
            </div>

            <!-- Dolor 2 -->
            <div
              class="border border-slate-200 rounded-lg bg-white shadow-sm overflow-hidden transition-all duration-300 hover:shadow-md pain-accordion-item"
            >
              <button
                type="button"
                class="pain-trigger w-full px-5 py-4 flex items-center justify-between text-left text-sm sm:text-base font-bold text-slate-800 hover:text-slate-900 transition-colors cursor-pointer outline-none"
                data-target="pain-ans-2"
              >
                <span class="flex items-center gap-3">
                  <span class="text-lg flex-shrink-0">📍</span>
                  <span>Ceguera Total Entre Tiendas (Multi-sucursal)</span>
                </span>
                <span
                  class="text-brand-secondary text-lg font-mono leading-none font-bold pain-icon transition-transform duration-300"
                  >+</span
                >
              </button>
              <div
                id="pain-ans-2"
                class="pain-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out"
              >
                <p
                  class="px-5 pb-4 pt-1 text-xs sm:text-sm text-slate-600 leading-relaxed pl-11"
                >
                  El cliente te pide un repuesto que no te queda en ese
                  mostrador. Sabes que podrías tenerlo en tu otra tienda, pero
                  como tu software actual no está integrado en línea, tu
                  vendedor tiene que colgarse del teléfono a llamar a la otra
                  sucursal mientras el cliente se desespera y se va.
                </p>
              </div>
            </div>

            <!-- Dolor 3 -->
            <div
              class="border border-slate-200 rounded-lg bg-white shadow-sm overflow-hidden transition-all duration-300 hover:shadow-md pain-accordion-item"
            >
              <button
                type="button"
                class="pain-trigger w-full px-5 py-4 flex items-center justify-between text-left text-sm sm:text-base font-bold text-slate-800 hover:text-slate-900 transition-colors cursor-pointer outline-none"
                data-target="pain-ans-3"
              >
                <span class="flex items-center gap-3">
                  <span class="text-lg flex-shrink-0">📍</span>
                  <span>La "Cacería a Ciegas" en el Almacén</span>
                </span>
                <span
                  class="text-brand-secondary text-lg font-mono leading-none font-bold pain-icon transition-transform duration-300"
                  >+</span
                >
              </button>
              <div
                id="pain-ans-3"
                class="pain-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out"
              >
                <p
                  class="px-5 pb-4 pt-1 text-xs sm:text-sm text-slate-600 leading-relaxed pl-11"
                >
                  Tu kárdex dice que te quedan 2 unidades de un rodamiento
                  pesado, pero nadie sabe en qué rincón, fila o estante del
                  almacén físico están escondidas. Tu personal pierde tiempo
                  buscando a ciegas mientras el mostrador se llena de gente.
                </p>
              </div>
            </div>

            <!-- Dolor 4 -->
            <div
              class="border border-slate-200 rounded-lg bg-white shadow-sm overflow-hidden transition-all duration-300 hover:shadow-md pain-accordion-item"
            >
              <button
                type="button"
                class="pain-trigger w-full px-5 py-4 flex items-center justify-between text-left text-sm sm:text-base font-bold text-slate-800 hover:text-slate-900 transition-colors cursor-pointer outline-none"
                data-target="pain-ans-4"
              >
                <span class="flex items-center gap-3">
                  <span class="text-lg flex-shrink-0">📍</span>
                  <span
                    >Ventas Congeladas por Productos sin Precios Actualizados</span
                  >
                </span>
                <span
                  class="text-brand-secondary text-lg font-mono leading-none font-bold pain-icon transition-transform duration-300"
                  >+</span
                >
              </button>
              <div
                id="pain-ans-4"
                class="pain-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out"
              >
                <p
                  class="px-5 pb-4 pt-1 text-xs sm:text-sm text-slate-600 leading-relaxed pl-11"
                >
                  Llega mercadería nueva o realizas una 'compra en plaza' de
                  emergencia para salvar un pedido. El vendedor intenta digitar
                  el producto, pero como el sistema no tiene un precio asignado,
                  la pantalla se bloquea. La venta se detiene por completo
                  esperando la autorización manual del dueño.
                </p>
              </div>
            </div>
          </div>

          <!-- Cierre de Contraste (Caja de Texto Destacada) -->
          <div
            class="mt-8 bg-orange-50 border-l-4 border-brand-secondary p-5 rounded-r-lg shadow-sm"
          >
            <p
              class="text-xs sm:text-sm text-slate-800 leading-relaxed font-semibold italic"
            >
              Los sistemas tradicionales fueron diseñados para registrar papeles
              en una oficina administrativa de traje, no para soportar la
              presión, la velocidad y el caos real de la calle repuestera debido
              a su alta competencia.
            </p>
          </div>
        </div>

        <!-- Columna Derecha (40%): Elemento multimedia principal (Mockup anotado) -->
        <div class="lg:col-span-5 space-y-6 flex flex-col justify-center">
          <div class="relative py-4 px-2 sm:px-4">
            <!-- Mockup Laptop Frame / Browser Window -->
            <div
              class="bg-slate-900 rounded-xl border border-slate-700/80 shadow-2xl overflow-hidden text-left font-sans select-none relative z-10"
            >
              <!-- Browser Mock Header -->
              <div
                class="bg-slate-950 px-4 py-3 border-b border-slate-800 flex items-center justify-between"
              >
                <div class="flex items-center gap-1.5">
                  <span class="w-2.5 h-2.5 rounded-full bg-red-500/80"></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/80"
                  ></span>
                  <span class="w-2.5 h-2.5 rounded-full bg-green-500/80"></span>
                </div>
              </div>

              <!-- App UI Mock Content -->
              <div class="p-4 sm:p-5 space-y-4 bg-slate-950 text-slate-100">
                <!-- Search Input Mock -->
                <div class="space-y-1.5">
                  <label
                    class="text-[9px] uppercase font-bold tracking-wider text-slate-400"
                    >SÚPER BUSCADOR UNIFICADO EN MOSTRADOR</label
                  >
                  <div class="relative flex items-center">
                    <input
                      type="text"
                      readonly
                      value="Toyota Hilux 2022"
                      class="w-full bg-slate-900 border border-brand-secondary text-slate-200 text-xs py-2 px-3 rounded font-mono font-semibold focus:outline-none"
                    />
                    <div class="absolute right-3 text-brand-secondary text-xs">
                      🔍
                    </div>
                  </div>
                  <p class="text-[8px] text-slate-400 italic">
                    Buscando por: "Nro. de parte alternativo o aplicación..."
                  </p>
                </div>

                <!-- Product Details Block (Descripción, Ubicación y Precio) -->
                <div
                  class="grid grid-cols-3 gap-2.5 p-3 bg-slate-900 border border-slate-800 rounded-lg text-[9px] sm:text-xs"
                >
                  <div class="space-y-1">
                    <span
                      class="text-[7.5px] uppercase font-bold tracking-wider text-slate-400 block font-mono font-bold"
                      >Descripción / Marca</span
                    >
                    <span
                      class="text-slate-100 font-bold block text-[10px] sm:text-[11px] leading-tight"
                      >Pastilla Freno Delantera</span
                    >
                    <span class="text-[8px] text-slate-400 font-mono block"
                      >Bosch (Equiv: 04465-0K340)</span
                    >
                  </div>
                  <div class="space-y-1">
                    <span
                      class="text-[7.5px] uppercase font-bold tracking-wider text-slate-400 block font-mono font-bold"
                      >Ubicación física</span
                    >
                    <span
                      id="mock-ubicacion"
                      class="inline-flex bg-brand-secondary/20 border border-brand-secondary/40 text-brand-secondary font-bold px-1.5 py-0.5 rounded font-mono text-[9px] sm:text-[10px]"
                    >
                      Fila 3, Estante B, Col. 1
                    </span>
                  </div>
                  <div class="space-y-1">
                    <span
                      class="text-[7.5px] uppercase font-bold tracking-wider text-slate-400 block font-mono font-bold"
                      >Precio Unitario</span
                    >
                    <span
                      class="text-emerald-400 font-extrabold block text-xs sm:text-sm font-mono"
                      >S/. 120.00</span
                    >
                    <span class="text-[8.5px] text-slate-400 block font-mono"
                      >IGV Incluido</span
                    >
                  </div>
                </div>

                <!-- Search Results Table -->
