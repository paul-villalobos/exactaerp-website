  // SCROLL-CONTROLLED STICKY BOTTOM BAR
  function setupStickyBar() {
    const stickyBar = document.getElementById("sticky-bar");
    const contactWidget = document.getElementById("contact-widget-container");

    window.addEventListener("scroll", () => {
      if (stickyBar) {
        // Show when user scrolls down past 600px
        if (window.scrollY > 600) {
          stickyBar.classList.remove("translate-y-24");
          stickyBar.classList.add("translate-y-0");

          // Shift floating widgets up to avoid overlap with sticky bar
          if (contactWidget) {
            contactWidget.classList.remove("bottom-6");
            contactWidget.classList.add("bottom-24");
          }
        } else {
          stickyBar.classList.remove("translate-y-0");
          stickyBar.classList.add("translate-y-24");

          // Restore floating elements down
          if (contactWidget) {
            contactWidget.classList.remove("bottom-24");
            contactWidget.classList.add("bottom-6");
          }
        }
      }
    });
  }

  // INTERACTIVE PROGRESS STEPS (Adoption Timeline)
  function setupAdoptionSteps() {
    const steps = document.querySelectorAll(".adoption-step");
    const progressBar = document.getElementById("adoption-progress-bar");

    if (steps.length === 0 || !progressBar) return;

    steps.forEach((step, idx) => {
      step.addEventListener("mouseenter", () => {
        const stepNum = idx + 1;
        const progressPercentage = (stepNum / steps.length) * 100;
        progressBar.style.width = `${progressPercentage}%`;

        // Update step visual states
        steps.forEach((s, sIdx) => {
          const numEl = s.querySelector(".step-num");
          if (!numEl) return;
          if (sIdx <= idx) {
            numEl.classList.add(
              "border-brand-secondary",
              "text-brand-secondary",
            );
            numEl.classList.remove("border-slate-900", "text-slate-600");
          } else {
            numEl.classList.add("border-slate-900", "text-slate-600");
            numEl.classList.remove(
              "border-brand-secondary",
              "text-brand-secondary",
            );
          }
        });
      });
    });
  }

  // CTA FEASIBILITY DRILLDOWN TO SCHEDULER DRAWER
  function setupFeasibilityCTA() {
    const feasibilityBtn = document.getElementById("btn-schedule-feasibility");
    const schedulerTrigger = document.getElementById("scheduler-trigger");
    const optScheduleBtn = document.getElementById("btn-opt-schedule");

    if (!feasibilityBtn) return;

    feasibilityBtn.addEventListener("click", () => {
      if (schedulerTrigger) {
        // Toggle the drawer if it is closed
        const drawer = document.getElementById("scheduler-drawer");
        if (drawer && drawer.classList.contains("opacity-0")) {
          schedulerTrigger.click();
        }
        if (optScheduleBtn) {
          optScheduleBtn.click();
        }
      }
    });
  }

