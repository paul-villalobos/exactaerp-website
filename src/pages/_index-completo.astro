---
import LandingLayout from "../layouts/LandingLayout.astro";
import ContactWidget from "../components/ContactWidget.astro";
import { Image } from "astro:assets";
import logoHorizontal from "../assets/logo-horizontal.png";
---

<LandingLayout
  title="ERP Exacta | Sistema de Control Comercial y Márgenes en Vivo"
  description="ERP comercial peruano para importadores, distribuidoras y servicios. Blinda tus márgenes y gestiona tu kárdex SUNAT en tiempo real sin cierres de mes."
  ogImage="/logo-vertical.png"
>
  <!-- Header: Menú de Navegación "Anti-Fugas" -->
  <header
    class="sticky top-0 z-50 w-full border-b border-slate-800 bg-slate-950/80 backdrop-blur-md"
  >
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between"
    >
      <!-- Lado Izquierdo: Logotipo -->
      <a href="#hero" class="flex items-center">
        <Image
          src={logoHorizontal}
          alt="ERP EXACTA"
          height={44}
          class="h-11 w-auto object-contain"
        />
      </a>

      <!-- Centro: Navegación de Anclaje Interno -->
      <nav class="hidden md:flex items-center gap-x-8">
        <a
          href="#enrutador-compuertas"
          class="text-sm font-medium text-slate-400 hover:text-slate-100 transition-colors"
        >
          Sistemas
        </a>
        <a
          href="#filtro-escala"
          class="text-sm font-medium text-slate-400 hover:text-slate-100 transition-colors"
        >
          Filtro Escala
        </a>
        <a
          href="#musculo-transaccional"
          class="text-sm font-medium text-slate-400 hover:text-slate-100 transition-colors"
        >
          Respaldo
        </a>
        <a
          href="#diagnostico-ia"
          class="text-sm font-medium text-slate-400 hover:text-slate-100 transition-colors"
        >
          Diagnóstico IA
        </a>
      </nav>

      <!-- Lado Derecho: El Botón de Conversión -->
      <div class="flex flex-col items-end">
        <a
          href="https://wa.me/51999647337?text=Hola%20Exacta%20ERP,%20deseo%20solicitar%20una%20demo%20de%20diagnóstico%20en%20mi%20local%20de%20repuestos."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-4 py-2 text-xs sm:text-sm font-bold text-slate-950 bg-brand-secondary hover:bg-brand-secondary-hover rounded-md shadow-lg shadow-brand-secondary/20 transition-all hover:scale-105 active:scale-95"
        >
          <!-- WhatsApp SVG Icon -->
          <svg class="w-4 h-4 mr-2 fill-current" viewBox="0 0 24 24">
            <path
              d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.262 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.73-1.458L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.825 1.451 5.436 0 9.86-4.42 9.863-9.864.002-2.634-1.02-5.11-2.884-6.978C16.578 1.897 14.1 .874 11.482.874 6.044.874 1.622 5.293 1.62 10.733c-.001 1.739.46 3.43 1.333 4.937L1.922 20.3l4.725-1.146zm11.378-6.196c-.302-.151-1.785-.882-2.057-.981-.273-.099-.471-.148-.669.151-.197.297-.767.966-.94 1.164-.173.199-.347.223-.649.072-.302-.15-1.272-.469-2.423-1.496-.895-.798-1.5-.178-1.785-.328-.287-.15-.03-.233.243-.506.244-.244.347-.396.52-.66.173-.264.086-.495-.043-.649-.129-.152-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.568-.01-.197 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.785-.73 2.037-1.435.252-.706.252-1.312.177-1.435-.077-.122-.273-.196-.576-.347z"
            ></path>
          </svg>
          Solicitar Demo
        </a>
      </div>
    </div>
  </header>
  <!-- SECCIÓN 1: HERO SECTION -->
  <section
    id="hero"
    class="relative overflow-hidden pt-12 pb-16 md:py-24 bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 border-b border-slate-900"
  >
    <!-- Background glow accents -->
    <div
      class="absolute top-0 left-1/3 w-[500px] h-[500px] bg-brand-primary/10 rounded-full blur-[100px] -z-10"
    >
    </div>
    <div
      class="absolute bottom-10 right-10 w-[400px] h-[400px] bg-brand-secondary/5 rounded-full blur-[80px] -z-10"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Currency switcher discretely floating at top-right of Hero content -->
      <div class="flex items-center justify-end gap-2 mb-6">
        <span
          class="text-[10px] uppercase font-bold tracking-wider font-mono text-slate-450"
          >Multi-Moneda:</span
        >
        <div
          class="bg-slate-900 border border-slate-800 p-0.5 rounded-lg inline-flex relative"
        >
          <button
            id="currency-switch-soles"
            class="px-3 py-1 rounded-md text-[10px] sm:text-xs font-bold font-mono transition-all bg-brand-secondary text-slate-950 cursor-pointer"
            data-currency="PEN"
          >
            Soles (S/.)
          </button>
          <button
            id="currency-switch-dolares"
            class="px-3 py-1 rounded-md text-[10px] sm:text-xs font-bold font-mono transition-all text-slate-450 hover:text-slate-200 cursor-pointer"
            data-currency="USD"
          >
            Dólares ($)
          </button>
        </div>
      </div>

      <div
        class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center"
      >
        <!-- Left Column: Copy -->
        <div class="lg:col-span-7 space-y-6 text-left">
          <!-- Market Context Cintillo -->
          <div
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-secondary/30 bg-brand-secondary/10"
          >
            <span class="w-2 h-2 rounded-full bg-brand-secondary animate-pulse"
            ></span>
            <span
              class="text-xs font-bold text-orange-350 tracking-wide uppercase font-mono"
            >
              SISTEMA DE CONTROL OPERATIVO Y MÁRGENES DE GANANCIA EN VIVO
            </span>
          </div>

          <!-- Main Title H1 -->
          <h1
            class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-white leading-tight"
          >
            El ERP comercial que toma el control donde los sistemas
            tradicionales se rompen.
          </h1>

          <!-- Support Subtitle H2 -->
          <h2
            class="text-base sm:text-lg text-slate-300 leading-relaxed max-w-2xl"
            data-astro-cid-lcdefpme
          >
            Sincroniza tus almacenes, protege tus márgenes por pedido en vivo y
            automatiza tu Inventario Permanente Valorizado bajo los estándares
            de la SUNAT.
            <span
              class="block mt-2 text-brand-secondary font-semibold font-mono text-xs sm:text-sm"
              >⚡ Control en tiempo real • Sin detener tu mostrador • Sin
              cierres de mes.</span
            >
          </h2>

          <!-- Call to Action -->
          <div class="space-y-3 pt-2">
            <div
              class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4"
            >
              <a
                href="#diagnostico-ia"
                class="inline-flex items-center justify-center px-8 py-4 bg-brand-secondary hover:bg-brand-secondary-hover text-slate-950 font-bold text-base rounded-md shadow-xl shadow-brand-secondary/20 hover:shadow-brand-secondary/30 transition-all hover:scale-105 active:scale-95 text-center cursor-pointer"
              >
                📊 Iniciar Diagnóstico de Fugas de Margen
              </a>
            </div>
            <p class="text-xs text-slate-400 font-medium">
              Toma menos de 2 minutos vía chat. Calcula cuánto está perdiendo tu
              negocio hoy.
            </p>
          </div>
        </div>

        <!-- Right Column: Simulated Management Dashboard (HTML/CSS UI) -->
        <div class="lg:col-span-5 flex justify-center">
          <div
            class="w-full max-w-md bg-slate-900 border border-slate-800 rounded-xl overflow-hidden shadow-2xl relative"
          >
            <!-- Simulated application top bar -->
            <div
              class="bg-slate-950 px-4 py-3 border-b border-slate-800 flex items-center justify-between"
            >
              <div class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-red-500/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-green-500/80"></span>
              </div>
              <span
                class="text-[10px] font-mono text-slate-450 font-bold uppercase tracking-wider"
              >
                ERP Exacta — PANEL GERENCIAL
              </span>
              <span
                class="text-[9px] bg-emerald-950 border border-emerald-800 text-emerald-400 px-2 py-0.5 rounded font-mono font-bold animate-pulse"
              >
                EN VIVO
              </span>
            </div>

            <!-- Dashboard Content -->
            <div
              class="p-4 sm:p-5 space-y-4 bg-slate-950/70 text-slate-100 font-sans"
            >
              <!-- Grid KPIs -->
              <div class="grid grid-cols-2 gap-3">
                <!-- Utilidad Bruta Proyectada del Día -->
                <div
                  class="bg-slate-900 border border-slate-800 p-3.5 rounded-lg relative overflow-hidden group hover:border-slate-700/80 transition-all col-span-2"
                >
                  <span
                    class="text-[9px] text-slate-400 font-bold uppercase block tracking-wider"
                    >Utilidad Bruta Proyectada del Día</span
                  >
                  <div
                    class="text-2xl sm:text-3xl font-black text-white font-mono mt-1 currency-value"
                    id="kpi-utilidad-bruta"
                    data-pen="S/. 12,450"
                    data-usd="$3,365"
                  >
                    S/. 12,450
                  </div>
                  <span
                    class="text-[10px] font-mono font-semibold text-emerald-400 flex items-center gap-1 mt-1"
                  >
                    ▲ +14.2% <span class="text-[8px] text-slate-500 font-normal"
                      >vs ayer</span
                    >
                  </span>
                  <div
                    class="absolute bottom-0 right-0 left-0 h-0.5 bg-gradient-to-r from-emerald-500 to-teal-400"
                  >
                  </div>
                </div>

                <!-- Estado de Pedidos en Mostrador -->
                <div
                  class="bg-slate-900 border border-slate-800 p-3.5 rounded-lg relative overflow-hidden group hover:border-slate-700/80 transition-all col-span-2"
                >
                  <span
                    class="text-[9px] text-slate-400 font-bold uppercase block tracking-wider"
                    >Estado de Pedidos en Mostrador</span
                  >
                  <div
                    class="text-xl sm:text-2xl font-black text-white font-mono mt-1"
                    id="kpi-transito-pedidos"
                  >
                    48 Pedidos
                  </div>
                  <span
                    class="text-[10px] font-mono font-semibold text-sky-400 flex items-center gap-1 mt-1"
                  >
                    ● Almacén de Tránsito en vivo <span
                      class="text-[8px] text-slate-500 font-normal"
                      >sin trabas</span
                    >
                  </span>
                  <div
                    class="absolute bottom-0 right-0 left-0 h-0.5 bg-gradient-to-r from-sky-500 to-indigo-400"
                  >
                  </div>
                </div>
              </div>

              <!-- Alertas de Margen Protegido (Audit/Leak control) -->
              <div class="space-y-1.5">
                <span
                  class="text-[9px] text-slate-450 font-bold uppercase tracking-wider block font-mono"
                  >Control de Fugas de Margen</span
                >
                <div
                  class="bg-red-950/30 border border-red-500/30 rounded p-3 text-red-300 text-[10px] sm:text-[11px] font-mono flex items-start gap-2 shadow-lg"
                >
                  <span class="text-red-500 animate-pulse text-xs">⛔</span>
                  <div>
                    <strong class="font-bold text-red-400 block text-[10px]"
                      >ALERTA DE DESVIACIÓN DE MARGEN:</strong
                    >
                    Vendedor <span class="text-white font-semibold"
                      >"Tienda 1"</span
                    > intentó vender por debajo del margen mínimo: <span
                      class="text-red-400 font-bold uppercase">BLOQUEADO</span
                    >
                  </div>
                </div>
              </div>
            </div>

            <!-- Dashboard Footer -->
            <div
              class="p-3 bg-slate-900 border-t border-slate-800 text-[10px] text-slate-400 flex items-center justify-between"
            >
              <span>Auditoría de márgenes activa</span>
              <span class="font-mono text-[9px] text-slate-500"
                >Módulos: Inventario / Importación / SUNAT</span
              >
            </div>
          </div>
        </div>
      </div>

      <!-- Widget de Enrutamiento de Balfour (Las 3 Compuertas Visuales) -->
      <div
        class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-16 pt-12 border-t border-slate-850 relative z-10"
      >
        <!-- Tarjeta 1 -->
        <a
          href="/repuestos"
          class="bg-slate-900/60 border border-slate-850 hover:border-brand-secondary/40 rounded-xl p-5 flex flex-col justify-between transition-all hover:-translate-y-1 duration-300 group cursor-pointer"
        >
          <div class="space-y-3">
            <div class="flex items-center gap-2.5">
              <span
                class="text-lg bg-orange-950/40 border border-brand-secondary/30 p-1.5 rounded-lg text-brand-secondary"
              >
                📦
              </span>
              <h3
                class="text-sm font-bold text-white group-hover:text-brand-secondary transition-colors"
              >
                Importación, Repuestos y Distribución
              </h3>
            </div>
            <p class="text-xs text-slate-400 leading-relaxed">
              ¿Operas con miles de códigos, equivalencias y velocidad de
              mostrador? <span
                class="text-brand-secondary font-semibold group-hover:underline inline-block"
                >[Ver Solución ->]</span
              >
            </p>
          </div>
        </a>

        <!-- Tarjeta 2 -->
        <a
          href="/servicios-industriales"
          class="bg-slate-900/60 border border-slate-850 hover:border-brand-primary/40 rounded-xl p-5 flex flex-col justify-between transition-all hover:-translate-y-1 duration-300 group cursor-pointer"
        >
          <div class="space-y-3">
            <div class="flex items-center gap-2.5">
              <span
                class="text-lg bg-blue-950/40 border border-brand-primary/30 p-1.5 rounded-lg text-brand-primary"
              >
                🔧
              </span>
              <h3
                class="text-sm font-bold text-white group-hover:text-brand-primary transition-colors"
              >
                Servicios Industriales y Talleres
              </h3>
            </div>
            <p class="text-xs text-slate-400 leading-relaxed">
              ¿Controlas programación de campo, activos y costos de mano de
              obra? <span
                class="text-brand-primary font-semibold group-hover:underline inline-block"
                >[Ver Solución ->]</span
              >
            </p>
          </div>
        </a>

        <!-- Tarjeta 3 -->
        <a
          href="/comercializadoras"
          class="bg-slate-900/60 border border-slate-850 hover:border-orange-500/30 rounded-xl p-5 flex flex-col justify-between transition-all hover:-translate-y-1 duration-300 group cursor-pointer"
        >
          <div class="space-y-3">
            <div class="flex items-center gap-2.5">
              <span
                class="text-lg bg-orange-950/20 border border-orange-500/20 p-1.5 rounded-lg text-orange-400"
              >
                🏪
              </span>
              <h3
                class="text-sm font-bold text-white group-hover:text-orange-400 transition-colors"
              >
                Comercializadoras y Alta Transaccionalidad
              </h3>
            </div>
            <p class="text-xs text-slate-400 leading-relaxed">
              ¿Diriges retail, catering o casinos con flujo de caja diario
              pesado? <span
                class="text-orange-400 font-semibold group-hover:underline inline-block"
                >[Ver Solución ->]</span
              >
            </p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 2: EL ENRUTADOR DE COMPUERTAS (StoryBrand & Pain-Benefit Router) -->
  <section
    id="enrutador-compuertas"
    class="py-24 bg-slate-950 border-b border-slate-900 relative"
  >
    <!-- Visual background accent -->
    <div
      class="absolute top-1/4 left-1/2 w-[350px] h-[350px] bg-brand-primary/5 rounded-full blur-[80px] -z-10"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
        <h2
          class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-white tracking-tight leading-tight"
        >
          Tres realidades de negocio distintas. Tres sistemas Exacta
          parametrizados a su medida.
        </h2>
        <p
          class="text-slate-350 text-xs sm:text-sm md:text-base leading-relaxed"
        >
          No creemos en los softwares 'enlatados' de talla única. Selecciona el
          Core operativo de tu empresa y descubre cómo ERP Exacta resuelve tus
          cuellos de botella específicos en vivo.
        </p>
      </div>

      <!-- 3 Compuertas Cards Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- COMPUERTA 1: Importación, Repuestos y Distribución Mayorista -->
        <div
          class="bg-slate-900/50 border border-slate-850 hover:border-brand-secondary/40 rounded-2xl p-6 sm:p-8 flex flex-col justify-between transition-all hover:-translate-y-2 duration-300 group relative"
        >
          <div class="space-y-6">
            <!-- Header Area -->
            <div>
              <span
                class="text-[9px] uppercase tracking-wider font-bold font-mono text-brand-secondary bg-orange-950/40 border border-brand-secondary/30 px-2 py-0.5 rounded"
              >
                SISTEMA DE MÁRGENES Y CONTROL MULTITIENDA
              </span>
              <h3 class="text-lg font-bold text-white mt-3">
                Distribución, Repuestos e Importaciones
              </h3>
            </div>

            <!-- Hover Animation Graphic (Almacén de Tránsito) -->
            <div
              class="h-28 bg-slate-950/60 border border-slate-800 rounded-lg p-3 flex flex-col justify-between overflow-hidden relative transition-colors group-hover:border-brand-secondary/30"
            >
              <div
                class="flex items-center justify-between text-[9px] font-mono border-b border-slate-900 pb-1"
              >
                <span class="text-slate-400 font-bold">ALMACÉN DE TRÁNSITO</span
                >
                <span class="text-brand-secondary font-bold animate-pulse"
                  >EN TRÁNSITO</span
                >
              </div>
              <div class="flex items-center justify-between gap-2 relative">
                <div class="flex flex-col items-center gap-1">
                  <span class="text-xs">📦</span>
                  <span class="text-[7px] text-slate-500 font-mono"
                    >Stock Negativo</span
                  >
                </div>
                <div class="flex-1 h-0.5 bg-slate-800 relative overflow-hidden">
                  <div
                    class="absolute inset-y-0 w-6 bg-brand-secondary/80 rounded animate-marquee-arrow"
                    style="left: -10px;"
                  >
                  </div>
                </div>
                <div class="flex flex-col items-center gap-1">
                  <span class="text-xs">🏢</span>
                  <span class="text-[7px] text-emerald-400 font-mono font-bold"
                    >Kárdex Real</span
                  >
                </div>
              </div>
              <div class="text-[8px] text-slate-450 text-center font-mono">
                Prorrateo & Costeo Contenedores Activo
              </div>
            </div>

            <!-- Pain Points (Espejo del Dolor) -->
            <div class="space-y-2">
              <span
                class="text-[9px] uppercase font-bold text-slate-500 tracking-wider block"
                >Puntos de Dolor Críticos:</span
              >
              <ul class="space-y-2 text-xs text-slate-350">
                <li class="flex items-start gap-2">
                  <span class="text-red-500/80 text-xs">⚠️</span>
                  <span
                    >¿Tus vendedores inventan stock o fuerzan ventas en negativo
                    para no perder clientes en mostrador?</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-500/80 text-xs">⚠️</span>
                  <span
                    >¿Sufres el calvario fiscal de regularizar las 'compras en
                    plaza' de emergencia?</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-red-500/80 text-xs">⚠️</span>
                  <span
                    >¿Tus costos de importación se calculan tarde en hojas de
                    Excel manuales?</span
                  >
                </li>
              </ul>
            </div>

            <!-- Superpower Area -->
            <div
              class="bg-slate-950/50 border border-slate-850 p-4 rounded-xl space-y-1.5"
            >
              <strong
                class="text-[9px] font-bold text-emerald-400 uppercase tracking-widest block font-mono"
                >El Superpoder de Exacta:</strong
              >
              <p class="text-[11px] sm:text-xs text-slate-300 leading-relaxed">
                Maneja la velocidad del mostrador sin perder el control de tu
                kárdex. Factura sin stock de forma legal con nuestro Almacén de
                Tránsito y calcula el costeo de tus contenedores en un solo clic
                con 4 métodos de prorrateo nativos.
              </p>
            </div>
          </div>

          <!-- Bottom CTA & Logos -->
          <div class="pt-6 mt-6 border-t border-slate-850 space-y-4">
            <a
              href="/repuestos"
              class="w-full inline-flex items-center justify-center py-2.5 px-4 bg-brand-secondary/10 hover:bg-brand-secondary text-brand-secondary hover:text-slate-950 font-bold text-xs uppercase tracking-wider rounded border border-brand-secondary/30 hover:border-brand-secondary transition-all text-center cursor-pointer"
            >
              Explorar Solución de Distribución →
            </a>
            <div class="space-y-1.5 pt-1">
              <span
                class="text-[8px] uppercase font-bold text-slate-500 font-mono block tracking-wider"
                >Validado por:</span
              >
              <div
                class="flex flex-wrap gap-2 items-center opacity-65 hover:opacity-100 transition-opacity"
              >
                <span
                  class="px-1.5 py-0.5 bg-slate-950 text-[9px] font-mono text-slate-400 border border-slate-800"
                  >M&M REPUESTOS</span
                >
                <span
                  class="px-1.5 py-0.5 bg-slate-950 text-[9px] font-mono text-slate-400 border border-slate-800"
                  >AUTOREX</span
                >
                <span
                  class="px-1.5 py-0.5 bg-slate-950 text-[9px] font-mono text-slate-400 border border-slate-800"
                  >EPIZENTRUM</span
                >
                <span
                  class="px-1.5 py-0.5 bg-slate-950 text-[9px] font-mono text-slate-400 border border-slate-800"
                  >NISSAN</span
                >
              </div>
            </div>
          </div>
        </div>

