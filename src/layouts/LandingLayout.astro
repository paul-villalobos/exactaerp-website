---
import "../styles/global.css";
import { Image } from "astro:assets";
import logoPalestra from "../assets/LOGO-PALESTRA.png";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  robots?: string;
}

const { 
  title, 
  description, 
  ogImage = "/logo-vertical.png", 
  robots = "index, follow" 
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content={robots} />

    <!-- Open Graph / Facebook / LinkedIn / WhatsApp -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:locale" content="es_PE" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- Structured Data: JSON-LD -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Palestra Sistemas E.I.R.L.",
        "image": "https://erpexacta.com/logo-vertical.png",
        "@id": "https://erpexacta.com/#localbusiness",
        "url": "https://erpexacta.com",
        "telephone": "+51999647337",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Calle Coyllur 449 SJL",
          "addressLocality": "Lima",
          "addressRegion": "Lima",
          "postalCode": "15401",
          "addressCountry": "PE"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": -12.022497235039218,
          "longitude": -76.98130657355956
        },
        "hasMap": "https://maps.app.goo.gl/VSpkfA9gZEttBw3e6",
        "sameAs": [
          "https://www.facebook.com/PalestraLabs/",
          "https://www.linkedin.com/company/palestra/"
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Exacta ERP",
        "operatingSystem": "All",
        "applicationCategory": "BusinessApplication",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "PEN"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "ratingCount": "42"
        }
      }
    ])} />

    <!-- YouTube Preconnect Optimizations -->
    <link rel="preconnect" href="https://www.youtube-nocookie.com" />
    <link rel="preconnect" href="https://googleads.g.doubleclick.net" />
    <link rel="preconnect" href="https://static.doubleclick.net" />
  </head>
  <body
    class="bg-slate-950 text-slate-100 min-h-screen flex flex-col font-sans selection:bg-brand-secondary selection:text-white"
  >
    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer: El Cierre de Seguridad Legal y de Autoridad -->
    <footer
      class="bg-slate-900 border-t border-slate-800 text-slate-300 text-sm py-12"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <!-- Bloque 1: Respaldo Institucional y Legitimidad -->
          <div class="space-y-4">
            <Image
              src={logoPalestra}
              alt="Palestra Sistemas"
              height={32}
              class="h-8 w-auto object-contain"
            />
            <p class="text-xs leading-relaxed text-slate-300">
              ERP EXACTA es una solución de Palestra Sistemas. Más de 200
              proyectos tecnológicos entregados de forma exitosa y convenios
              institucionales vigentes con universidades líderes del Perú
              (UNMSM, Creatika Labs, Inverbotics Group).
            </p>
          </div>

          <!-- Bloque 3: Datos de Contacto Directo -->
          <div class="space-y-4">
            <span
              class="text-slate-100 font-bold text-xs uppercase tracking-wider block"
              >Contacto Directo</span
            >
            <div class="space-y-2 text-xs">
              <p class="flex items-start">
                <span class="font-semibold text-slate-300 mr-1.5"
                  >Oficinas:</span
                >
                Calle Coyllur 449 SJL, Lima, Perú.
              </p>
              <p class="flex items-center">
                <span class="font-semibold text-slate-300 mr-1.5">Correo:</span>
                <a
                  href="mailto:wilver.villalobos@sdkpalestra.com"
                  class="hover:text-white transition-colors"
                  >wilver.villalobos@sdkpalestra.com</a
                >
              </p>
              <p class="flex items-center">
                <span class="font-semibold text-slate-300 mr-1.5"
                  >Teléfono:</span
                >
                <a
                  href="tel:+51999647337"
                  class="hover:text-white transition-colors">+51 999 647 337</a
                >
              </p>
              <p class="flex items-center">
                <span class="font-semibold text-slate-300 mr-1.5">Canal:</span>
                <span class="text-brand-secondary font-semibold"
                  >Atención Preferencial B2B</span
                >
              </p>
            </div>
          </div>
        </div>

        <div
          class="mt-8 pt-8 border-t border-slate-800 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-450"
        >
          <p>
            © 2026 ERP EXACTA - Palestra Sistemas. Todos los derechos
            reservados.
          </p>
          <p class="font-mono">
            ERP EXACTA • Soluciones de gestión para autopartes.
          </p>
        </div>
      </div>
    </footer>

    <!-- LIGHTWEIGHT OVERLAYS / MODALS FOR LEGAL COMPLIANCE -->
    <dialog
      id="modal-privacidad"
      class="backdrop:bg-slate-950/80 bg-slate-900 border border-slate-800 rounded-lg p-6 max-w-2xl w-full text-slate-300 shadow-2xl relative"
    >
      <h3 class="text-lg font-bold text-white mb-4">Políticas de Privacidad</h3>
      <div class="space-y-3 text-xs overflow-y-auto max-h-[60vh] pr-2">
        <p>
          <strong>1. Recolección de Datos:</strong> Palestra Sistemas recopila la
          información suministrada voluntariamente en nuestros formularios de contacto,
          demostraciones y widgets de agendamiento para gestionar visitas y demostraciones
          de software.
        </p>
        <p>
          <strong>2. Uso de la Información:</strong> Los datos se emplean única y
          exclusivamente con fines de contacto comercial para la solución ERP EXACTA.
          Bajo ninguna circunstancia vendemos ni compartimos sus datos personales
          con terceros.
        </p>
        <p>
          <strong>3. Derechos ARCO:</strong> Como titular de sus datos personales,
          usted puede solicitar el acceso, rectificación, cancelación u oposición
          al uso de su información escribiendo a <em
            >wilver.villalobos@sdkpalestra.com</em
          >.
        </p>
      </div>
      <div class="mt-6 flex justify-end">
        <button
          onclick="document.getElementById('modal-privacidad').close()"
          class="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-white rounded text-xs cursor-pointer"
        >
          Entendido / Cerrar
        </button>
      </div>
    </dialog>

    <dialog
      id="modal-terminos"
      class="backdrop:bg-slate-950/80 bg-slate-900 border border-slate-800 rounded-lg p-6 max-w-2xl w-full text-slate-300 shadow-2xl relative"
    >
      <h3 class="text-lg font-bold text-white mb-4">Términos del Servicio</h3>
      <div class="space-y-3 text-xs overflow-y-auto max-h-[60vh] pr-2">
        <p>
          <strong>1. Descripción del Servicio:</strong> ERP EXACTA es un software
          integral de administración comercial y contabilidad desarrollado por Palestra
          Sistemas E.I.R.L, enfocado en el sector de distribuidoras de repuestos y
          autopartes en Perú.
        </p>
        <p>
          <strong>2. Licenciamiento y Uso:</strong> El acceso a ERP EXACTA se realiza
          bajo el modelo SaaS (Software como Servicio). Las cuentas y accesos quedan
          limitados a las sucursales y licencias acordadas contractualmente.
        </p>
        <p>
          <strong>3. Integración SUNAT:</strong> El sistema provee conexión con Proveedores
          de Servicios Electrónicos autorizados. El cliente es responsable final por
          la veracidad de la información tributaria enviada a la SUNAT.
        </p>
      </div>
      <div class="mt-6 flex justify-end">
        <button
          onclick="document.getElementById('modal-terminos').close()"
          class="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-white rounded text-xs cursor-pointer"
        >
          Entendido / Cerrar
        </button>
      </div>
    </dialog>

    <dialog
      id="modal-reclamaciones"
      class="backdrop:bg-slate-950/80 bg-slate-900 border border-slate-800 rounded-lg p-6 max-w-2xl w-full text-slate-300 shadow-2xl relative"
    >
      <h3 class="text-lg font-bold text-white mb-4">
        Libro de Reclamaciones Virtual
      </h3>
      <form
        class="space-y-3 text-xs"
        onsubmit="event.preventDefault(); alert('Reclamo registrado de forma simulada. Nos contactaremos a la brevedad.'); document.getElementById('modal-reclamaciones').close();"
      >
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-slate-400 mb-1">Nombre Completo</label>
            <input
              type="text"
              required
              class="w-full bg-slate-950 border border-slate-800 rounded p-2 focus:border-brand-secondary outline-none text-slate-100"
            />
          </div>
          <div>
            <label class="block text-slate-400 mb-1">RUC o DNI</label>
            <input
              type="text"
              required
              class="w-full bg-slate-950 border border-slate-800 rounded p-2 focus:border-brand-secondary outline-none text-slate-100"
            />
          </div>
        </div>
        <div>
          <label class="block text-slate-400 mb-1">Correo Electrónico</label>
          <input
            type="email"
            required
            class="w-full bg-slate-950 border border-slate-800 rounded p-2 focus:border-brand-secondary outline-none text-slate-100"
          />
        </div>
        <div>
          <label class="block text-slate-400 mb-1">Tipo de Reclamación</label>
          <select
            class="w-full bg-slate-950 border border-slate-800 rounded p-2 focus:border-brand-secondary outline-none text-slate-100"
          >
            <option
              >Queja (Descontento no relacionado directamente a los productos)</option
            >
            <option>Reclamo (Inconformidad con el servicio adquirido)</option>
          </select>
        </div>
        <div>
          <label class="block text-slate-400 mb-1"
            >Detalle del reclamo o queja</label
          >
          <textarea
            required
            rows="4"
            class="w-full bg-slate-950 border border-slate-800 rounded p-2 focus:border-brand-secondary outline-none text-slate-100 resize-none"
          ></textarea>
        </div>
        <div class="mt-4 flex justify-between gap-3">
          <button
            type="button"
            onclick="document.getElementById('modal-reclamaciones').close()"
            class="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-white rounded cursor-pointer"
          >
            Cancelar
          </button>
          <button
            type="submit"
            class="px-4 py-2 bg-brand-secondary hover:bg-brand-secondary-hover text-white font-bold rounded cursor-pointer"
          >
            Enviar Reclamación
          </button>
        </div>
      </form>
    </dialog>
  </body>
</html>
